        // ============== ORDER MODE: MEAL MENU + ORDER-TAKING ==============
        function getMealMenu(section) {
            const data = dataForSection(section);
            if (!data) return [];
            if (!data.mealMenu) data.mealMenu = [];
            return data.mealMenu;
        }

        function getOrderLetter(p, section) {
            if (!p || !p.orderChoiceId) return '';
            const menu = getMealMenu(section);
            const choice = menu.find(function (c) { return c.id === p.orderChoiceId; });
            if (!choice || !choice.name) return '';
            const trimmed = choice.name.trim();
            return trimmed ? trimmed.charAt(0).toUpperCase() : '';
