                const hasAnyData = p.title || p.name.replace('/', '') || p.meal || p.tier || p.specialCode || p.isInfant || p.extSeatbelt || (p.remarksText && p.remarksText.trim());
                if (!hasAnyData) markSeatAsEmpty(seatBox);
