        function saveInfoEdit(section, seat) {
            const data = dataForSection(section);
            if (!data) return;
            if (!data.passengers) data.passengers = [];
            let p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) { p = { seat: seat }; data.passengers.push(p); }

            const title = document.getElementById('editTitle').value;
