                    '<input type="number" min="0" class="meal-menu-qty" value="' + choice.qty + '" onchange="updateMealMenuField(\'' + section + '\',\'' + choice.id + '\',\'qty\',this.value)">' +
                    '<button class="meal-menu-remove-btn" onclick="removeMealChoice(\'' + section + '\',\'' + choice.id + '\')">\u2715</button>' +
