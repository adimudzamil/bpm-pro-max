    <!-- Order-taking modal (tap a seat's meal line in Order mode) -->
    <div id="orderModalOverlay" class="panel-overlay" onclick="if(event.target===this) closeOrderModal()">
        <div class="panel-modal" id="orderModalBody"></div>
