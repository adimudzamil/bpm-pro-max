    <script>
        // ============== THEME CONSTANTS ==============
        const DEFAULT_TIER_COLORS = {
            ELIT: { bg: '#e3f2fd', text: '#0d47a1' },
            PLAT: { bg: '#f3e5f5', text: '#4a148c' },
            GOLD: { bg: '#fff8e1', text: '#e65100' },
            RUBY: { bg: '#ffebee', text: '#b71c1c' },
            SLVR: { bg: '#eceff1', text: '#37474f' },
            BLUE: { bg: '#e1f5fe', text: '#01579b' },
            SAPH: { bg: '#e8eaf6', text: '#1a237e' },
            EMER: { bg: '#ffcdd2', text: '#b71c1c' }
        };
        const MEAL_PALETTE = ['#c8e6c9','#ffe0b2','#b3e5fc','#f8bbd0','#d1c4e9','#fff9c4','#b2dfdb','#ffccbc','#c5cae9','#dcedc8'];
        const SPECIAL_PALETTE = ['#bbdefb','#c5cae9','#d1c4e9','#b39ddb','#90caf9','#80deea','#b2ebf2','#cfd8dc'];
        const ORDER_PALETTE = ['#fff3cd','#d4edda','#cce5ff','#f8d7da','#e2d9f3','#d1ecf1','#fde2e2','#e8f5e9'];
        const SPECIAL_CODES = ['DEPO', 'MAAS', 'MEDA', 'NTL', 'UM', 'VVIP', 'WCHC', 'WCHR', 'WCHS', 'YPTA', 'LMU X Meal', 'LMU EY Meal'];
        const THEME_STORAGE_KEY = 'bpmSeatChartTheme';
        const TABS_STORAGE_KEY = 'bpmReportTabs';

        let theme = null;

        function getSpecialLabel(p) {
            if (!p || !p.specialCode) return '';
            if (p.specialCode === 'OTHERS') {
                return p.specialOtherText ? p.specialOtherText.trim().toUpperCase() : '';
            }
            return p.specialCode;
        }

        function defaultTheme() {
            return {
                structural: {
                    borderColor: '#000000', seatBg: '#ffffff', headerBg: '#f0f0f0', headerText: '#000000',
                    titleColor: '#000000', nameColor: '#000000', mealBg: '#f0f0f0', mealText: '#000000',
                    emptyPlaceholder: '#cccccc'
                },
                tiers: JSON.parse(JSON.stringify(DEFAULT_TIER_COLORS)),
                mealColors: {},
                specialColors: {},
                orderColors: {}
            };
        }

        function loadTheme() {
            try {
                const raw = localStorage.getItem(THEME_STORAGE_KEY);
                theme = raw ? JSON.parse(raw) : defaultTheme();
            } catch (e) { theme = defaultTheme(); }
            const d = defaultTheme();
            theme.structural = Object.assign(d.structural, theme.structural || {});
            theme.tiers = Object.assign(d.tiers, theme.tiers || {});
            theme.mealColors = theme.mealColors || {};
            theme.specialColors = theme.specialColors || {};
            theme.orderColors = theme.orderColors || {};
        }

        function saveTheme() {
            try { localStorage.setItem(THEME_STORAGE_KEY, JSON.stringify(theme)); } catch (e) { console.error('Theme save failed', e); }
        }

        function resetThemeToDefaults() {
            theme = defaultTheme();
            saveTheme();
            applyTheme();
            showToast('Colours reset to defaults');
        }

        function exportTheme() {
            try {
                const dataStr = JSON.stringify(theme, null, 2);
                const blob = new Blob([dataStr], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'bpm-seat-chart-colours-backup.json';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                showToast('\u2713 Colour theme backed up');
            } catch (e) {
                console.error('Theme export failed', e);
                showToast('Backup failed');
            }
        }

        function triggerImportTheme() {
            document.getElementById('themeImportInput').click();
        }

        function importThemeFromFile(event) {
            const file = event.target.files && event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const imported = JSON.parse(e.target.result);
                    theme = imported;
                    const d = defaultTheme();
                    theme.structural = Object.assign(d.structural, theme.structural || {});
                    theme.tiers = Object.assign(d.tiers, theme.tiers || {});
                    theme.mealColors = theme.mealColors || {};
                    theme.specialColors = theme.specialColors || {};
                    theme.orderColors = theme.orderColors || {};
                    saveTheme();
                    applyTheme();
                    if (currentMode === 'color') renderTierColorChips();
                    showToast('\u2713 Colour theme restored');
                } catch (err) {
                    console.error('Theme import failed', err);
                    showToast('Could not read that file');
                }
                event.target.value = '';
            };
            reader.readAsText(file);
        }

        function applyTheme() {
            const s = theme.structural;
            const root = document.documentElement.style;
            root.setProperty('--sc-border-color', s.borderColor);
            root.setProperty('--sc-seat-bg', s.seatBg);
            root.setProperty('--sc-header-bg', s.headerBg);
            root.setProperty('--sc-header-text', s.headerText);
            root.setProperty('--sc-title-color', s.titleColor);
            root.setProperty('--sc-name-color', s.nameColor);
            root.setProperty('--sc-meal-default-bg', s.mealBg);
            root.setProperty('--sc-meal-default-text', s.mealText);
            root.setProperty('--sc-empty-placeholder', s.emptyPlaceholder);
            Object.keys(theme.tiers).forEach(function (t) {
                root.setProperty('--sc-tier-' + t + '-bg', theme.tiers[t].bg);
                root.setProperty('--sc-tier-' + t + '-text', theme.tiers[t].text);
            });
            document.querySelectorAll('.field-line.meal-line').forEach(applyMealLineColors);
        }

        function hashCode(str) {
            let h = 0;
            for (let i = 0; i < str.length; i++) { h = ((h << 5) - h) + str.charCodeAt(i); h |= 0; }
            return h;
        }

        function getMealColor(code) {
            if (!code) return null;
            if (theme.mealColors[code]) return theme.mealColors[code];
            const idx = Math.abs(hashCode(code)) % MEAL_PALETTE.length;
            const c = { bg: MEAL_PALETTE[idx], text: '#000000' };
            theme.mealColors[code] = c;
            saveTheme();
            return c;
        }

        function getSpecialColor(code) {
            if (!code) return null;
            if (theme.specialColors[code]) return theme.specialColors[code];
            const idx = Math.abs(hashCode(code + '::special')) % SPECIAL_PALETTE.length;
            const c = { bg: SPECIAL_PALETTE[idx], text: '#000000' };
            theme.specialColors[code] = c;
            saveTheme();
            return c;
        }

        function getOrderColor(choiceId) {
            if (!choiceId) return { bg: '#ffffff', text: '#000000' };
            if (theme.orderColors[choiceId]) return theme.orderColors[choiceId];
            const idx = Math.abs(hashCode(choiceId + '::order')) % ORDER_PALETTE.length;
            const c = { bg: ORDER_PALETTE[idx], text: '#000000' };
            theme.orderColors[choiceId] = c;
            saveTheme();
            return c;
        }

        function applyMealLineColors(mealField) {
            const mealSpan = mealField.querySelector('.meal-code-part');
            if (mealSpan) {
                const code = mealSpan.getAttribute('data-meal-code');
                const c = getMealColor(code);
                mealSpan.style.backgroundColor = c.bg;
                mealSpan.style.color = c.text;
            }
            const orderSpan = mealField.querySelector('.order-code-part');
            if (orderSpan) {
                const choiceId = orderSpan.getAttribute('data-order-choice');
                const c = getOrderColor(choiceId);
                orderSpan.style.backgroundColor = c.bg;
                orderSpan.style.color = c.text;
            }
            const specialSpan = mealField.querySelector('.special-code-part');
            if (specialSpan) {
                const code = specialSpan.getAttribute('data-special-code');
                const c = getSpecialColor(code);
                specialSpan.style.backgroundColor = c.bg;
                specialSpan.style.color = c.text;
            }
        }

        function showToast(msg) {
            let toast = document.getElementById('scToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'scToast';
                toast.style.cssText = 'position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:#1E3A8A;color:#fff;padding:8px 16px;border-radius:20px;font-size:12px;z-index:3000;box-shadow:0 4px 10px rgba(0,0,0,0.2);';
                document.body.appendChild(toast);
            }
            toast.textContent = msg;
            toast.style.opacity = '1';
            clearTimeout(window._scToastTimer);
            window._scToastTimer = setTimeout(function () { toast.style.opacity = '0'; }, 2000);
        }

        // ============== MODE MANAGEMENT ==============
        let currentMode = 'view'; // 'view' | 'color' | 'edit'
        let swapModeActive = false;
        let swapFirstSeat = null;

        function setMode(mode) {
            currentMode = mode;
            swapModeActive = false;
            clearSwapSelection();
            document.querySelectorAll('.mode-btn').forEach(function (b) {
                b.classList.toggle('active', b.dataset.mode === mode);
            });
            document.getElementById('swapSeatsBtn').style.display = mode === 'edit' ? 'inline-flex' : 'none';
            document.getElementById('swapSeatsBtn').classList.remove('active');
            document.getElementById('swapHint').style.display = 'none';
            document.body.classList.toggle('color-mode', mode === 'color');
            document.body.classList.toggle('edit-mode', mode === 'edit');
            document.body.classList.toggle('order-mode', mode === 'order');
            document.getElementById('tierColorChipsGroup').style.display = mode === 'color' ? 'flex' : 'none';
            if (mode === 'color') renderTierColorChips();
            document.getElementById('topMealMenuBtn').style.display = mode === 'order' ? 'inline-flex' : 'none';
            document.getElementById('bottomMealMenuBtn').style.display = mode === 'order' ? 'inline-flex' : 'none';
        }

        function renderTierColorChips() {
            const holder = document.getElementById('tierColorChips');
            holder.innerHTML = Object.keys(DEFAULT_TIER_COLORS).map(function (t) {
                const c = theme.tiers[t] || DEFAULT_TIER_COLORS[t];
                return '<span class="tier-chip" style="background:' + c.bg + ';color:' + c.text + ';" onclick="openTierColorPanel(\'' + t + '\')">' + t + '</span>';
            }).join('');
        }

        function toggleSwapMode() {
            swapModeActive = !swapModeActive;
            clearSwapSelection();
            document.getElementById('swapSeatsBtn').classList.toggle('active', swapModeActive);
            document.getElementById('swapHint').style.display = swapModeActive ? 'inline-block' : 'none';
        }

        function toggleMoreControls() {
            document.getElementById('controlBar').classList.toggle('collapsed');
        }

        function clearSwapSelection() {
            if (swapFirstSeat) swapFirstSeat.classList.remove('swap-selected');
            swapFirstSeat = null;
        }

        document.addEventListener('click', function (e) {
            if (currentMode === 'view') return;

            if (currentMode === 'edit') {
                const seatBox = e.target.closest('.seat-box');
                if (!seatBox) return;
                if (swapModeActive) { handleSwapTap(seatBox); return; }
                openInfoEditModal(seatBox);
                return;
            }

            if (currentMode === 'order') {
                const specialSpan = e.target.closest('.special-code-part');
                if (specialSpan) return; // special-assistance side is not editable here
                const mealLineHit = e.target.closest('.field-line.meal-line');
                if (!mealLineHit) return;
                const seatBox = mealLineHit.closest('.seat-box');
                if (!seatBox) return;
                openOrderModal(seatBox);
                return;
            }

            if (currentMode === 'color') {
                const tierBadge = e.target.closest('.tier');
                if (tierBadge) {
