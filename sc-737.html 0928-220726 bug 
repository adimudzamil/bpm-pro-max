        }

        function addMealChoice(section) {
            const menu = getMealMenu(section);
            menu.push({ id: 'meal_' + Date.now() + '_' + Math.floor(Math.random() * 1000), name: 'New Meal', qty: 0 });
            renderMealMenuSetup(section);
            renderMealCountSummary(section);
        }

        function removeMealChoice(section, choiceId) {
            const data = dataForSection(section);
            const menu = getMealMenu(section);
            const idx = menu.findIndex(function (c) { return c.id === choiceId; });
            if (idx === -1) return;
            if (data && data.passengers) {
                data.passengers.forEach(function (p) {
                    if (p.orderChoiceId === choiceId) {
                        p.orderChoiceId = null;
                        refreshSeatDisplay(section, p.seat);
                    }
                });
            }
            menu.splice(idx, 1);
            renderMealMenuSetup(section);
            renderMealCountSummary(section);
            syncBackToMainPage();
        }

        function updateMealMenuField(section, choiceId, field, value) {
            const menu = getMealMenu(section);
            const choice = menu.find(function (c) { return c.id === choiceId; });
            if (!choice) return;
            if (field === 'qty') {
                choice.qty = Math.max(0, parseInt(value, 10) || 0);
            } else {
                choice.name = value;
                const data = dataForSection(section);
                if (data && data.passengers) {
                    data.passengers.forEach(function (p) {
                        if (p.orderChoiceId === choiceId) refreshSeatDisplay(section, p.seat);
                    });
                }
            }
            renderMealCountSummary(section);
        }

        function closeMealMenuSetup() { document.getElementById('mealMenuOverlay').style.display = 'none'; }

        // ---- Order-taking (tap a seat's meal line in Order mode) ----
        function openOrderModal(seatBox) {
            const seat = seatBox.getAttribute('data-seat');
            const section = sectionForBox(seatBox);
            const data = dataForSection(section);
            if (!data) { showToast('No manifest loaded for this chart yet'); return; }
            if (seatBox.classList.contains('empty-seat')) { showToast('No passenger in this seat'); return; }
            if (!data.passengers) data.passengers = [];
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) { showToast('No passenger in this seat'); return; }
            if (p.meal && p.meal.trim()) { showToast('Seat ' + seat + ' already has a declared special meal: ' + p.meal); return; }
            if (getMealMenu(section).length === 0) { showToast('No meal choices set up yet \u2014 tap ðŸ½ï¸ Meal Menu first'); return; }

            renderOrderModal(section, seat);
            document.getElementById('orderModalOverlay').style.display = 'flex';
        }

        function renderOrderModal(section, seat) {
            const data = dataForSection(section);
            const menu = getMealMenu(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            const currentChoiceId = p ? p.orderChoiceId : null;

            let html = '<div class="edit-modal-title">Meal order \u2014 Seat ' + seat + '</div>';
            html += '<div id="orderMenuRows">';
            menu.forEach(function (choice) {
                const isSelected = choice.id === currentChoiceId;
                const isDisabled = choice.qty <= 0 && !isSelected;
                html += '<div class="meal-menu-row' + (isDisabled ? ' disabled' : '') + '">' +
                    '<span class="meal-menu-name" style="border:none;padding:6px 0;">' + choice.name + ' (' + choice.qty + ' left)</span>' +
                    '<button class="meal-menu-select-btn' + (isSelected ? ' active' : '') + '" ' + (isDisabled ? 'disabled' : '') + ' onclick="selectMealChoice(\'' + section + '\',\'' + seat + '\',\'' + choice.id + '\')">' + (isSelected ? '\u2713 Selected' : 'Select') + '</button>' +
                    '</div>';
            });
            html += '</div>';
            html += '<button class="btn-close-panel" onclick="closeOrderModal()">Done</button>';

            document.getElementById('orderModalBody').innerHTML = html;
        }

        function selectMealChoice(section, seat, choiceId) {
            const data = dataForSection(section);
            if (!data || !data.passengers) return;
            const menu = getMealMenu(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) return;
            const newChoice = menu.find(function (c) { return c.id === choiceId; });
            if (!newChoice) return;

            if (p.orderChoiceId === choiceId) {
                newChoice.qty += 1;
                p.orderChoiceId = null;
            } else {
                if (newChoice.qty <= 0) { showToast('No more ' + newChoice.name + ' left'); return; }
                if (p.orderChoiceId) {
                    const oldChoice = menu.find(function (c) { return c.id === p.orderChoiceId; });
                    if (oldChoice) oldChoice.qty += 1;
                }
                newChoice.qty -= 1;
                p.orderChoiceId = choiceId;
            }

            refreshSeatDisplay(section, seat);
            syncBackToMainPage();
            renderMealCountSummary(section);
            renderOrderModal(section, seat);
        }

        function refreshSeatDisplay(section, seat) {
            const data = dataForSection(section);
            if (!data || !data.passengers) return;
            const normSeat = normalizeSeatNumber(seat);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === normSeat; });
            const seatBox = document.querySelector('#' + section + 'SeatContainer [data-seat="' + normSeat + '"]');
            if (p && seatBox) populateSeatData(p, seatBox);
        }

        function closeOrderModal() { document.getElementById('orderModalOverlay').style.display = 'none'; }

        // ============== SUMMARY CHIPS + CATEGORY LIST ==============
        function renderSummaryChips(section) {
            const holder = document.getElementById(section + 'SummaryChips');
            if (!holder) return;
            const data = dataForSection(section);
            const passengers = (data && data.passengers) ? data.passengers : [];

            const specialCounts = {};
            passengers.forEach(function (p) {
                const label = getSpecialLabel(p);
                if (label) specialCounts[label] = (specialCounts[label] || 0) + 1;
            });
            const infCount = passengers.filter(function (p) { return p.isInfant; }).length;
            const extCount = passengers.filter(function (p) { return p.extSeatbelt; }).length;
            const remarksCount = passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); }).length;

            let chips = [];
            Object.keys(specialCounts).sort().forEach(function (code) {
                chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'special\',\'' + code.replace(/'/g, "\\'") + '\')">' + code + ' (' + specialCounts[code] + ')</span>');
            });
            if (infCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'inf\')">INF (' + infCount + ')</span>');
            if (extCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'ext\')">EXT (' + extCount + ')</span>');
            if (remarksCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'remarks\')">REMARKS (' + remarksCount + ')</span>');

            holder.innerHTML = chips.join('');
        }

        function openCategoryList(section, category, code) {
            const data = dataForSection(section);
            const passengers = (data && data.passengers) ? data.passengers : [];
            let items = [];
            let title = '';

            if (category === 'special') {
                title = code + ' (' + passengers.filter(function (p) { return getSpecialLabel(p) === code; }).length + ')';
                items = passengers.filter(function (p) { return getSpecialLabel(p) === code; })
                    .map(function (p) { return { seat: p.seat || 'â€”', name: p.name || '', tag: code }; });
            } else if (category === 'inf') {
                title = 'Infants (' + passengers.filter(function (p) { return p.isInfant; }).length + ')';
                items = passengers.filter(function (p) { return p.isInfant; })
                    .map(function (p) { return { seat: p.seat || 'â€”', name: p.name || '', tag: 'INF' }; });
            } else if (category === 'ext') {
                title = 'Extension Seatbelt (' + passengers.filter(function (p) { return p.extSeatbelt; }).length + ')';
                items = passengers.filter(function (p) { return p.extSeatbelt; })
                    .map(function (p) { return { seat: p.seat || 'â€”', name: p.name || '', tag: 'EXT' }; });
            } else if (category === 'remarks') {
                title = 'Remarks (' + passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); }).length + ')';
                items = passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); })
                    .map(function (p) { return { seat: p.seat || 'â€”', name: p.name || '', tag: p.remarksText }; });
            }

            items.sort(function (a, b) {
                if (a.seat === 'â€”') return 1;
                if (b.seat === 'â€”') return -1;
                return normalizeSeatNumber(a.seat).localeCompare(normalizeSeatNumber(b.seat));
            });

