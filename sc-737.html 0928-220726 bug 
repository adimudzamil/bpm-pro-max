            p.name = surname + '/' + firstname;
            p.meal = document.getElementById('editMeal').value.trim().toUpperCase();
            p.tier = document.getElementById('editTier').value;
            p.specialCode = document.getElementById('editSpecial').value;
            p.specialOtherText = document.getElementById('editSpecialOther').value.trim();
            p.isInfant = document.getElementById('editInfant').checked;
            p.extSeatbelt = document.getElementById('editExtSeatbelt').checked;
            p.remarksText = document.getElementById('editRemarks').value;
            p.seat = seat;

            const containerId = section + 'SeatContainer';
