    <!-- ════════ HOME VIEW ════════ -->
    <div class="view active" id="viewHome">
        <div class="home-body">

            <!-- Category cards -->
            <div class="cat-cards">
                <div class="cat-card ifs" onclick="openCat('ifs')">
                    <div class="cc-label">IFS</div>
                    <div class="cc-name">In-Flight Services</div>
                    <div class="cc-count" id="cnt-ifs">0</div>
                    <div class="cc-arrow">→</div>
                </div>
                <div class="cat-card ops" onclick="openCat('ops')">
                    <div class="cc-label">OPS</div>
                    <div class="cc-name">Ops Planning &amp; Support</div>
                    <div class="cc-count" id="cnt-ops">0</div>
                    <div class="cc-arrow">→</div>
                </div>
                <div class="cat-card fsoc" onclick="openCat('fsoc')">
                    <div class="cc-label">FSOC</div>
                    <div class="cc-name">Flight Safety</div>
