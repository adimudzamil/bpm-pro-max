<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MEMO.LOG">
    <meta name="theme-color" content="#001F4E">
    <title>MEMO.LOG</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🗂️</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* ══════════════════════════════════════════
           THEME VARIABLES
        ══════════════════════════════════════════ */
        :root {
            --bg: #F4F7FB;
            --surface: #FFFFFF;
            --surface2: #EEF3FA;
            --border: #D6E0EF;
            --border2: #C0CFDF;
            --text: #0D1F3C;
            --text2: #4A6280;
            --text3: #8FA3BC;
            --navy: #003580;
            --navy2: #001F4E;
            --navy3: #00418A;
            --gold: #C9A84C;
            --gold2: #E8C96A;
            --gold3: #FBF5E6;
            --ifs: #003580;
            --ifs-bg: #EBF1FB;
            --ops: #16A34A;
            --ops-bg: #ECFAF2;
            --fsoc: #DC2626;
            --fsoc-bg: #FEF2F2;
            --success: #16A34A;
            --error: #DC2626;
            --shadow: 0 2px 12px rgba(0, 31, 78, 0.08);
            --shadow2: 0 4px 24px rgba(0, 31, 78, 0.14);
            --radius: 10px;
            --header-h: 60px;
        }
        [data-theme="dark"] {
            --bg: #0D1525;
            --surface: #162035;
            --surface2: #1C2A42;
            --border: #243350;
            --border2: #2E4070;
            --text: #E8EEF7;
            --text2: #8FA3BC;
            --text3: #4A6280;
            --gold3: #1C2A42;
            --shadow: 0 2px 12px rgba(0, 0, 0, .3);
            --shadow2: 0 4px 24px rgba(0, 0, 0, .4);
        }
        [data-theme="black"] {
            --bg: #000;
            --surface: #0A0A0A;
            --surface2: #111;
            --border: #1A1A1A;
            --border2: #222;
            --text: #F0F0F0;
            --text2: #888;
            --text3: #444;
            --gold3: #0A0A0A;
            --shadow: 0 2px 12px rgba(0, 0, 0, .6);
            --shadow2: 0 4px 24px rgba(0, 0, 0, .8);
        }
        [data-theme="modern"] {
            --navy: #1D4ED8;
            --navy2: #1E3A8A;
            --navy3: #2563EB;
            --gold: #F59E0B;
            --gold2: #FCD34D;
            --gold3: #FFFBEB;
            --ifs: #1D4ED8;
            --ifs-bg: #EFF6FF;
            --ops: #059669;
            --ops-bg: #ECFDF5;
            --fsoc: #DC2626;
            --fsoc-bg: #FEF2F2;
        }

        /* ══════════════════════════════════════════
           RESET & BASE
        ══════════════════════════════════════════ */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        html {
            height: 100%;
            overflow: hidden;
        }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100%;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: background .2s, color .2s;
        }
        button {
            font-family: 'Inter', system-ui, sans-serif;
            cursor: pointer;
        }
        input,
        textarea,
        select {
            font-family: 'Inter', system-ui, sans-serif;
        }

        /* ══════════════════════════════════════════
           HEADER
        ══════════════════════════════════════════ */
        .hdr {
            height: var(--header-h);
            flex-shrink: 0;
            background: linear-gradient(135deg, var(--navy2), var(--navy));
            border-bottom: 2px solid var(--gold);
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 10px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, .25);
            position: relative;
            z-index: 100;
        }
        .hdr-back {
            background: none;
            border: none;
            color: rgba(255, 255, 255, .7);
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: none;
            align-items: center;
            justify-content: center;
            transition: background .15s;
            flex-shrink: 0;
        }
        .hdr-back:hover {
            background: rgba(255, 255, 255, .1);
        }
        .hdr-back svg {
            width: 18px;
            height: 18px;
        }
        .hdr-logo {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            line-height: 1.2;
        }
        .hdr-logo-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .hdr-emoji {
            font-size: 22px;
            line-height: 1;
        }
        .hdr-name {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            letter-spacing: .04em;
        }
        .hdr-name em {
            color: var(--gold);
            font-style: normal;
        }
        .hdr-sub {
            font-size: 9px;
            font-weight: 400;
            color: rgba(255, 255, 255, .35);
            letter-spacing: .12em;
            text-transform: uppercase;
            margin-left: 2px;
            line-height: 1.2;
        }
        .hdr-cat-label {
            font-size: 13px;
            font-weight: 700;
            color: rgba(255, 255, 255, .85);
            letter-spacing: .04em;
            display: none;
        }
        .hdr-spacer {
            flex: 1;
        }
        .hdr-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, .6);
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s, color .15s;
            flex-shrink: 0;
        }
        .hdr-btn:hover {
            background: rgba(255, 255, 255, .1);
            color: #fff;
        }
        .hdr-btn svg {
            width: 18px;
            height: 18px;
        }

        /* ══════════════════════════════════════════
           VIEW SYSTEM
        ══════════════════════════════════════════ */
        .view {
            display: none;
            flex: 1;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }
        .view.active {
            display: flex;
            flex-direction: column;
        }

        /* ══════════════════════════════════════════
           TOAST
        ══════════════════════════════════════════ */
        .toast {
            position: fixed;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(20px);
            background: var(--navy2);
            color: #fff;
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .02em;
            border-left: 3px solid var(--gold);
            box-shadow: var(--shadow2);
            opacity: 0;
            transition: all .25s ease;
            z-index: 9999;
            pointer-events: none;
            white-space: nowrap;
            max-width: 90vw;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
        .toast.ok {
            border-left-color: #22C55E;
        }
        .toast.err {
            border-left-color: #EF4444;
        }

        /* ══════════════════════════════════════════
           MODAL
        ══════════════════════════════════════════ */
        .modal-wrap {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 500;
            background: rgba(0, 0, 0, .5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            padding: 16px;
        }
        .modal-wrap.open {
            display: flex;
        }
        .modal {
            background: var(--surface);
            border-radius: 14px;
            width: 100%;
            max-width: 440px;
            box-shadow: var(--shadow2);
            overflow: hidden;
            animation: modalIn .2s ease;
        }
        @keyframes modalIn {
            from {
                opacity: 0;
                transform: scale(.95)
            }
            to {
                opacity: 1;
                transform: scale(1)
            }
        }
        .modal-hdr {
            background: linear-gradient(135deg, var(--navy2), var(--navy));
            border-bottom: 2px solid var(--gold);
            padding: 14px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .modal-title {
            font-size: 14px;
            font-weight: 800;
            color: #fff;
            letter-spacing: .04em;
        }
        .modal-title em {
            color: var(--gold);
            font-style: normal;
        }
        .modal-x {
            background: none;
            border: none;
            color: rgba(255, 255, 255, .5);
            font-size: 22px;
            line-height: 1;
            padding: 0 2px;
            transition: color .15s;
        }
        .modal-x:hover {
            color: #fff;
        }
        .modal-body {
            padding: 16px;
        }
        .modal-body p {
            font-size: 13px;
            color: var(--text2);
            line-height: 1.6;
            margin-bottom: 12px;
        }
        .modal-row {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            justify-content: flex-end;
        }
        .mbtn {
            border: none;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 700;
            padding: 9px 18px;
            letter-spacing: .04em;
            transition: all .15s;
        }
        .mbtn.primary {
            background: var(--navy);
            color: #fff;
        }
        .mbtn.primary:hover {
            background: var(--navy3);
        }
        .mbtn.cancel {
            background: var(--surface2);
            color: var(--text2);
            border: 1px solid var(--border);
        }
        .mbtn.cancel:hover {
            border-color: var(--border2);
        }
        .mbtn.danger {
            background: #EF4444;
            color: #fff;
        }
        .mbtn.danger:hover {
            background: #DC2626;
        }

        /* ══════════════════════════════════════════
           HOME VIEW
        ══════════════════════════════════════════ */
        .home-body {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Category cards */
        .cat-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }
        .cat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 12px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            cursor: pointer;
            transition: all .18s;
            position: relative;
            overflow: hidden;
        }
        .cat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }
        .cat-card.ifs::before {
            background: var(--ifs);
        }
        .cat-card.ops::before {
            background: var(--ops);
        }
        .cat-card.fsoc::before {
            background: var(--fsoc);
        }
        .cat-card:hover {
            box-shadow: var(--shadow2);
            transform: translateY(-1px);
        }
        .cat-card:active {
            transform: translateY(0);
        }
        .cc-label {
            font-size: 9px;
            font-weight: 800;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--text3);
        }
        .cc-name {
            font-size: 10px;
            font-weight: 600;
            color: var(--text2);
            line-height: 1.3;
        }
        .cc-count {
            font-size: 26px;
            font-weight: 800;
            color: var(--navy);
            line-height: 1;
            margin-top: 2px;
        }
        [data-theme="dark"] .cc-count,
        [data-theme="black"] .cc-count {
            color: var(--gold);
        }
        .cc-arrow {
            font-size: 10px;
            color: var(--text3);
            align-self: flex-end;
        }

        /* Upload panel */
        .upload-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }
        .up-hdr {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .up-hdr-title {
            font-size: 12px;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--text2);
        }
        .up-body {
            padding: 14px;
        }
        .drop-zone {
            border: 2px dashed var(--border2);
            border-radius: 8px;
            padding: 24px 16px;
            text-align: center;
            transition: all .2s;
            margin-bottom: 12px;
        }
        .drop-zone.drag-over {
            border-color: var(--gold);
            background: var(--gold3);
        }
        .dz-icon {
            font-size: 28px;
            margin-bottom: 8px;
        }
        .dz-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 4px;
        }
        [data-theme="dark"] .dz-title,
        [data-theme="black"] .dz-title {
            color: var(--gold);
        }
        .dz-hint {
            font-size: 11px;
            color: var(--text3);
            line-height: 1.5;
        }
        .browse-btns {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .browse-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: 9px 16px;
            transition: background .15s;
        }
        .browse-btn:hover {
            background: var(--navy3);
        }
        .browse-btn.secondary {
            background: var(--surface2);
            color: var(--text2);
            border: 1px solid var(--border2);
        }
        .browse-btn.secondary:hover {
            border-color: var(--navy);
            color: var(--navy);
        }
        #imgInput,
        #pdfInput {
            position: absolute;
            left: -9999px;
            width: 1px;
            height: 1px;
            opacity: 0;
        }

        /* Progress bar */
        .proc-wrap {
            display: none;
            margin-bottom: 12px;
        }
        .proc-wrap.show {
            display: block;
        }
        .proc-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }
        .proc-label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text2);
        }
        .proc-pct {
            font-size: 11px;
            color: var(--text3);
        }
        .proc-bar-bg {
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .proc-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--navy), var(--gold));
            border-radius: 2px;
            width: 0;
            transition: width .3s;
        }

        /* Parse log */
        .parse-log {
            display: none;
        }
        .parse-log.show {
            display: block;
        }
        .pl-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .pl-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--text3);
        }
        .pl-clear {
            font-size: 11px;
            color: var(--text3);
            background: none;
            border: none;
            text-decoration: underline;
            cursor: pointer;
        }
        .pl-clear:hover {
            color: var(--error);
        }
        .pl-rows {
            display: flex;
            flex-direction: column;
            gap: 4px;
            max-height: 200px;
            overflow-y: auto;
        }
        .pl-row {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 6px;
            font-size: 11px;
            line-height: 1.4;
        }
        .pl-row.ok {
            background: #F0FDF4;
            border: 1px solid #BBF7D0;
        }
        [data-theme="dark"] .pl-row.ok,
        [data-theme="black"] .pl-row.ok {
            background: #0D2818;
            border-color: #166534;
        }
        .pl-row.fail {
            background: #FFF5F5;
            border: 1px solid #FECACA;
        }
        [data-theme="dark"] .pl-row.fail,
        [data-theme="black"] .pl-row.fail {
            background: #2A0D0D;
            border-color: #7F1D1D;
        }
        .pl-icon {
            flex-shrink: 0;
            font-size: 13px;
            margin-top: 1px;
        }
        .pl-text {
            flex: 1;
            color: var(--text2);
        }
        .pl-ref {
            font-weight: 700;
            color: var(--navy);
        }
        [data-theme="dark"] .pl-ref,
        [data-theme="black"] .pl-ref {
            color: var(--gold2);
        }

        /* DB bar */
        .db-bar {
            background: var(--gold3);
            border: 1px solid #E8D9A0;
            border-radius: var(--radius);
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        [data-theme="dark"] .db-bar,
        [data-theme="black"] .db-bar {
            border-color: var(--border);
        }
        .db-bar-label {
            font-size: 10px;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--navy);
            flex-shrink: 0;
        }
        [data-theme="dark"] .db-bar-label,
        [data-theme="black"] .db-bar-label {
            color: var(--gold);
        }
        .db-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border: none;
            border-radius: 6px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            padding: 6px 12px;
            transition: all .15s;
            white-space: nowrap;
        }
        .db-btn.primary {
            background: var(--navy);
            color: #fff;
        }
        .db-btn.primary:hover {
            background: var(--navy3);
        }
        .db-btn.gold {
            background: var(--gold);
            color: var(--navy2);
        }
        .db-btn.gold:hover {
            background: var(--gold2);
        }
        .db-btn.ghost {
            background: var(--surface);
            color: var(--text2);
            border: 1px solid var(--border2);
        }
        .db-btn.ghost:hover {
            border-color: var(--navy);
            color: var(--navy);
        }
        .db-spacer {
            flex: 1;
        }
        .db-info {
            font-size: 10px;
            color: var(--text3);
            font-style: italic;
        }

        /* ══════════════════════════════════════════
           CATEGORY VIEW
        ══════════════════════════════════════════ */
        .cat-view-body {
            display: flex;
            flex-direction: column;
            flex: 1;
            overflow: hidden;
        }

        /* Cat toolbar */
        .cat-toolbar {
            padding: 10px 14px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            flex-shrink: 0;
        }
        .ct-sort {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text2);
            cursor: pointer;
            transition: all .15s;
        }
        .ct-sort:hover {
            border-color: var(--navy);
            color: var(--navy);
        }
        .ct-spacer {
            flex: 1;
        }
        .ct-search {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 6px 10px;
        }
        .ct-search svg {
            width: 13px;
            height: 13px;
            color: var(--text3);
            flex-shrink: 0;
        }
        .ct-search input {
            border: none;
            outline: none;
            background: transparent;
            font-size: 12px;
            color: var(--text);
            width: 140px;
        }
        .ct-search input::placeholder {
            color: var(--text3);
        }
        .ct-add {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .06em;
            padding: 6px 12px;
            transition: background .15s;
        }
        .ct-add:hover {
            background: var(--navy3);
        }

        /* Mini upload bar in cat view */
        .cat-upload-bar {
            padding: 8px 14px;
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            flex-wrap: wrap;
        }
        .cub-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--text3);
        }
        .cub-spacer {
            flex: 1;
        }

        /* Table wrapper */
        .table-wrap {
            flex: 1;
            overflow: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* Table */
        .memo-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            min-width: 600px;
        }
        .memo-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .memo-table th {
            background: var(--navy2);
            color: rgba(255, 255, 255, .75);
            padding: 10px 12px;
            text-align: left;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            white-space: nowrap;
            user-select: none;
        }
        .memo-table th:first-child {
            width: 40px;
            text-align: center;
        }
        .th-inner {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .th-menu-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, .3);
            padding: 0;
            margin-left: 2px;
            line-height: 1;
            transition: color .15s;
            cursor: pointer;
            font-size: 14px;
        }
        .th-menu-btn:hover {
            color: var(--gold);
        }
        .memo-table td {
            padding: 9px 12px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            color: var(--text);
        }
        .memo-table tbody tr {
            transition: background .1s;
        }
        .memo-table tbody tr:hover {
            background: var(--surface2);
        }
        .memo-table tbody tr.editing {
            background: var(--gold3);
        }
        [data-theme="dark"] .memo-table tbody tr.editing,
        [data-theme="black"] .memo-table tbody tr.editing {
            background: var(--surface2);
        }
        .memo-table tbody tr.drag-over-row {
            border-top: 2px solid var(--gold);
        }

        /* Cell types */
        .td-num {
            text-align: center;
            color: var(--text3);
            font-size: 11px;
            width: 40px;
        }
        .td-ref {
            font-weight: 700;
            color: var(--navy);
            white-space: nowrap;
            font-size: 11px;
        }
        [data-theme="dark"] .td-ref,
        [data-theme="black"] .td-ref {
            color: var(--gold2);
        }
        .td-subject {
            min-width: 200px;
            line-height: 1.4;
        }
        .td-date {
            white-space: nowrap;
            font-size: 11px;
            color: var(--text2);
        }
        .td-actions {
            white-space: nowrap;
            text-align: right;
        }

        /* Row actions */
        .row-acts {
            display: flex;
            align-items: center;
            gap: 4px;
            justify-content: flex-end;
        }
        .ra-btn {
            width: 26px;
            height: 26px;
            border: none;
            border-radius: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--surface2);
            color: var(--text2);
            transition: all .15s;
            flex-shrink: 0;
        }
        .ra-btn:hover.copy {
            background: #EFF6FF;
            color: var(--navy);
        }
        .ra-btn:hover.edit {
            background: #FFF7ED;
            color: #C2410C;
        }
        .ra-btn:hover.del {
            background: #FEF2F2;
            color: var(--error);
        }
        .ra-btn:hover.drag {
            cursor: grab;
        }
        .ra-btn svg {
            width: 13px;
            height: 13px;
        }
        .copy-ok {
            background: #DCFCE7 !important;
            color: #16A34A !important;
        }

        /* Inline edit inputs */
        .edit-input {
            width: 100%;
            background: var(--surface);
            border: 1px solid var(--gold);
            border-radius: 4px;
            padding: 4px 7px;
            font-size: 12px;
            color: var(--text);
            outline: none;
        }
        .edit-save-btn {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 700;
            padding: 4px 10px;
            cursor: pointer;
            white-space: nowrap;
        }

        /* Empty state */
        .empty-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 20px;
            color: var(--text3);
            text-align: center;
        }
        .empty-emoji {
            font-size: 40px;
            margin-bottom: 12px;
            opacity: .4;
        }
        .empty-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text2);
            margin-bottom: 6px;
        }
        .empty-sub {
            font-size: 12px;
            line-height: 1.6;
        }

        /* ══════════════════════════════════════════
           SETTINGS VIEW
        ══════════════════════════════════════════ */
        .settings-body {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .settings-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }
        .ss-hdr {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
        }
        .ss-body {
            padding: 12px 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .ss-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }
        .ss-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }
        .ss-sub {
            font-size: 11px;
            color: var(--text3);
            margin-top: 1px;
        }

        /* Theme picker */
        .theme-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        .theme-btn {
            padding: 10px 12px;
            border-radius: 7px;
            border: 2px solid var(--border);
            background: var(--surface2);
            cursor: pointer;
            text-align: left;
            transition: all .15s;
        }
        .theme-btn:hover {
            border-color: var(--gold);
        }
        .theme-btn.active {
            border-color: var(--gold);
            background: var(--gold3);
        }
        .tb-name {
            font-size: 12px;
            font-weight: 700;
            color: var(--text);
        }
        .tb-sub {
            font-size: 10px;
            color: var(--text3);
            margin-top: 2px;
        }
        .theme-btn .tb-swatch {
            width: 100%;
            height: 6px;
            border-radius: 3px;
            margin-bottom: 8px;
        }

        /* Col manager */
        .col-mgr {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .col-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 6px;
        }
        .col-drag {
            color: var(--text3);
            cursor: grab;
            flex-shrink: 0;
        }
        .col-name {
            flex: 1;
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
        }
        .col-toggle {
            width: 36px;
            height: 20px;
            border-radius: 10px;
            border: none;
            background: var(--border2);
            cursor: pointer;
            position: relative;
            transition: background .2s;
            flex-shrink: 0;
        }
        .col-toggle.on {
            background: var(--navy);
        }
        .col-toggle::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #fff;
            transition: transform .2s;
        }
        .col-toggle.on::after {
            transform: translateX(16px);
        }

        /* ══════════════════════════════════════════
           COLUMN HEADER DROPDOWN
        ══════════════════════════════════════════ */
        .col-menu {
            position: absolute;
            z-index: 200;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            box-shadow: var(--shadow2);
            min-width: 160px;
            overflow: hidden;
        }
        .col-menu-item {
            padding: 9px 14px;
            font-size: 12px;
            color: var(--text);
            cursor: pointer;
            transition: background .1s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .col-menu-item:hover {
            background: var(--surface2);
        }
        .col-menu-item.danger {
            color: var(--error);
        }
        .col-menu-item svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        /* ══════════════════════════════════════════
           IMPORT MODAL EXTRAS
        ══════════════════════════════════════════ */
        .import-drop {
            border: 2px dashed var(--border2);
            border-radius: 8px;
            padding: 24px 16px;
            text-align: center;
            cursor: pointer;
            transition: all .2s;
            margin-bottom: 12px;
        }
        .import-drop:hover,
        .import-drop.drag-over {
            border-color: var(--gold);
            background: var(--gold3);
        }
        .import-status {
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            display: none;
            margin-bottom: 10px;
        }
        .import-status.ok {
            display: block;
            background: #F0FDF4;
            color: #166534;
            border: 1px solid #BBF7D0;
        }
        .import-status.err {
            display: block;
            background: #FEF2F2;
            color: #991B1B;
            border: 1px solid #FECACA;
        }

        /* ══════════════════════════════════════════
           ADD ROW MODAL FORM
        ══════════════════════════════════════════ */
        .form-grid {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .form-row {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .form-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--text3);
        }
        .form-input {
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            padding: 8px 10px;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color .15s;
            width: 100%;
        }
        .form-input:focus {
            border-color: var(--navy);
        }

        /* ══════════════════════════════════════════
           SCROLLBAR
        ══════════════════════════════════════════ */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border2);
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--text3);
        }

        /* ══════════════════════════════════════════
           FOOTER CREDIT
        ══════════════════════════════════════════ */
        .footer {
            padding: 8px;
            text-align: center;
            font-size: 9px;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
            flex-shrink: 0;
            border-top: 1px solid var(--border);
        }
        .footer em {
            color: var(--gold);
        }

        /* ══════════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════════ */
        @media(max-width:480px) {
            .cat-cards {
                grid-template-columns: repeat(3, 1fr);
            }
            .cc-count {
                font-size: 22px;
            }
            .ct-search input {
                width: 100px;
            }
        }

        /* ── AUTO-SAVE STATUS CHIP ── */
        .as-chip {
            display: none;
            position: fixed;
            bottom: 16px;
            right: 16px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text2);
            box-shadow: var(--shadow);
            z-index: 300;
            align-items: center;
            gap: 6px;
            transition: opacity .3s;
        }
        .as-chip.show {
            display: flex;
        }
        .as-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--border2);
            flex-shrink: 0;
        }
        .as-dot.saving {
            background: #F59E0B;
            animation: pulse .8s infinite;
        }
        .as-dot.saved {
            background: #22C55E;
        }
        .as-dot.err {
            background: #EF4444;
        }
        @keyframes pulse {
            0%,
            100% {
                opacity: 1
            }
            50% {
                opacity: .3
            }
        }

        /* ── LINK FILE BUTTON in db bar ── */
        .db-btn.link {
            background: var(--surface);
            color: var(--text2);
            border: 1px solid var(--border2);
        }
        .db-btn.link:hover {
            border-color: var(--gold);
            color: var(--navy);
        }
        .db-btn.link.linked {
            border-color: #22C55E;
            color: #16A34A;
        }

        /* ── FIRST OPEN MODAL ── */
        .fo-modal {
            position: fixed;
            inset: 0;
            z-index: 600;
            background: rgba(0, 0, 0, .6);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }
        .fo-modal.open {
            display: flex;
        }
        .fo-box {
            background: var(--surface);
            border-radius: 14px;
            width: 100%;
            max-width: 400px;
            box-shadow: var(--shadow2);
            overflow: hidden;
            animation: modalIn .25s ease;
        }
        .fo-hdr {
            background: linear-gradient(135deg, var(--navy2), var(--navy));
            border-bottom: 2px solid var(--gold);
            padding: 16px;
        }
        .fo-hdr h2 {
            font-size: 16px;
            font-weight: 800;
            color: #fff;
            letter-spacing: .03em;
        }
        .fo-hdr h2 em {
            color: var(--gold);
            font-style: normal;
        }
        .fo-hdr p {
            font-size: 11px;
            color: rgba(255, 255, 255, .45);
            margin-top: 3px;
        }
        .fo-body {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .fo-body p {
            font-size: 13px;
            color: var(--text2);
            line-height: 1.6;
        }
        .fo-btns {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .fo-btn {
            border: none;
            border-radius: 8px;
            padding: 12px 16px;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all .15s;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .fo-btn.primary {
            background: var(--navy);
            color: #fff;
        }
        .fo-btn.primary:hover {
            background: var(--navy3);
        }
        .fo-btn.secondary {
            background: var(--surface2);
            color: var(--text2);
            border: 1px solid var(--border2);
        }
        .fo-btn.secondary:hover {
            border-color: var(--navy);
        }
        .fo-btn.ghost {
            background: none;
            color: var(--text3);
            font-size: 12px;
            padding: 8px 16px;
        }
        .fo-btn-icon {
            font-size: 18px;
            flex-shrink: 0;
        }

        /* ── MOBILE SAVE BANNER ── */
        .save-banner {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 400;
            background: var(--navy2);
            border-top: 2px solid var(--gold);
            padding: 12px 16px;
            flex-direction: row;
            align-items: center;
            gap: 10px;
            box-shadow: 0 -4px 20px rgba(0, 0, 0, .3);
        }
        .save-banner.show {
            display: flex;
        }
        .sb-text {
            flex: 1;
            font-size: 12px;
            color: rgba(255, 255, 255, .8);
            line-height: 1.4;
        }
        .sb-text strong {
            color: var(--gold2);
        }
        .sb-btn {
            border: none;
            border-radius: 6px;
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            font-weight: 700;
            padding: 8px 14px;
            cursor: pointer;
            white-space: nowrap;
            letter-spacing: .05em;
            text-transform: uppercase;
        }
        .sb-btn.save {
            background: var(--gold);
            color: var(--navy2);
        }
        .sb-btn.save:hover {
            background: var(--gold2);
        }
        .sb-btn.dismiss {
            background: rgba(255, 255, 255, .1);
            color: rgba(255, 255, 255, .6);
            margin-left: 4px;
        }

        /* ── LOADING SPINNER for Tesseract ── */
        .tess-loading {
            display: none;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            background: var(--surface2);
            border-radius: 6px;
            border: 1px solid var(--border);
            font-size: 11px;
            color: var(--text2);
            margin-top: 8px;
        }
        .tess-loading.show {
            display: flex;
        }
        .tess-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid var(--border2);
            border-top-color: var(--navy);
            border-radius: 50%;
            animation: spin .6s linear infinite;
            flex-shrink: 0;
        }
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body data-theme="ops">

