        function sortedMemos() {
            const list = memos.filter(m => m.cat === curCat);
            if (sortMode === 'newest') {
                list.sort((a, b) => {
                    const ka = refSortKey(a.ref),
                        kb = refSortKey(b.ref);
                    if (kb.year !== ka.year) return kb.year - ka.year;
                    return kb.num - ka.num;
                });
            } else {
                list.sort((a, b) => {
                    const ka = refSortKey(a.ref),
                        kb = refSortKey(b.ref);
                    if (ka.year !== kb.year) return ka.year - kb.year;
                    return ka.num - kb.num;
                });
            }
            return list;
