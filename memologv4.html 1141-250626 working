        function copyMemo(id) {
            const m = memos.find(x => x.id === id);
            if (!m) return;
            const line = `${m.ref} ${m.subject !== '—' ? m.subject : ''}`.trim();
            navigator.clipboard.writeText(line).then(() => {
                const btn = document.getElementById('cpbtn-' + id);
                if (btn) { btn.classList.add('copy-ok');
                    setTimeout(() => btn.classList.remove('copy-ok'), 1800); }
                toast('Copied!', 'ok');
            }).catch(() => {
                const ta = document.createElement('textarea');
                ta.value = line;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                toast('Copied!', 'ok');
            });
        }

        function startEdit(id) { editingId = id;
            renderTable(); }

        function cancelEdit() { editingId = null;
            renderTable(); }

        // ── CHANGE 4 (part 2): saveEdit with category move + dept mapping ──
        async function saveEdit(id) {
            const m = memos.find(x => x.id === id);
            if (!m) return;

            const row = document.querySelector(`tr[data-id="${id}"]`);
            if (!row) return;

            // Save text fields
            row.querySelectorAll('.edit-input').forEach(inp => {
                m[inp.dataset.key] = inp.value.trim();
            });

            // Read category selector
            const catSel = document.getElementById('catsel-' + id);
            if (catSel && catSel.value) {
                const newCat = catSel.value;
                if (newCat !== m.cat) {
                    // If user changed the category, ask if we should
                    // remember this dept code mapping for future parses
                    const deptParts = (m.ref || '').toUpperCase().split('/');
                    if (deptParts.length >= 2) {
                        const dept = deptParts[1];
                        const remember = confirm(
                            `Move this memo to "${newCat}"?\n\n` +
                            `Also remember: route all future "${dept}" memos to "${newCat}" automatically?`
                        );
                        if (remember) saveDeptMapping(dept, newCat);
                    }
                    m.cat = newCat;
                }
            }

            editingId = null;
            await persistOne(m);
            updateCounts();
            renderTable();
            toast('Saved', 'ok');
        }

        function openDeleteModal(id) {
            deleteId = id;
            const m = memos.find(x => x.id === id);
            document.getElementById('delModalRef').textContent = m ? m.ref : '';
            openModal('delModal');
        }

        async function confirmDelete() {
            if (!deleteId) return;
            memos = memos.filter(m => m.id !== deleteId);
            await removeOne(deleteId);
            deleteId = null;
            closeModal('delModal');
            updateCounts();
            renderTable();
            updateDbInfo();
            toast('Deleted', 'ok');
        }

        // ════════════════════════════════════════════════════════
        //  ADD ROW MODAL
        // ════════════════════════════════════════════════════════
        function openAddModal() {
            const form = document.getElementById('addForm');
            form.innerHTML = cols.map(c => `
              <div class="form-row">
                <label class="form-label">${c.label}</label>
                <input class="form-input" data-key="${c.key}" placeholder="${c.label}">
              </div>`).join('');
            openModal('addModal');
        }

        async function saveAddModal() {
            const inputs = document.querySelectorAll('#addForm .form-input');
            const data = {};
            inputs.forEach(i => { data[i.dataset.key] = i.value.trim(); });

            if (!data.ref) { toast('REF is required', 'err'); return; }
            const ref = data.ref.replace(/[-–]/g, '/').toUpperCase();
            if (memos.find(m => m.ref === ref)) { toast('REF already exists', 'err'); return; }

            const cat = detectCat(ref);
            if (!cat) { toast('Cannot detect category from REF', 'err'); return; }

            const memo = {
                id: `${Date.now()}-${Math.random().toString(36).slice(2,6)}`,
                cat,
                ref,
                subject: data.subject || '—',
                dateIssued: data.dateIssued || '—',
                effective: data.effective || '—',
                validity: data.validity || '—',
                sortOrder: 0,
                ts: new Date().toISOString()
            };
            memos.unshift(memo);
            await persistOne(memo);
            closeModal('addModal');
            updateCounts();
            if (curCat === cat) renderTable();
            updateDbInfo();
            toast('Memo added', 'ok');
        }

        // ════════════════════════════════════════════════════════
        //  DRAG TO REORDER
        // ════════════════════════════════════════════════════════
        let dragId = null;

        function onRowDragStart(e) {
            dragId = e.currentTarget.dataset.id;
            e.currentTarget.style.opacity = '.4';
        }

        function onRowDragOver(e) {
            e.preventDefault();
            document.querySelectorAll('.drag-over-row').forEach(r => r.classList.remove('drag-over-row'));
            e.currentTarget.classList.add('drag-over-row');
        }

        function onRowDrop(e) {
            e.preventDefault();
            const targetId = e.currentTarget.dataset.id;
            if (!dragId || dragId === targetId) return;
            const list = sortedMemos();
            const fromIdx = list.findIndex(m => m.id === dragId);
            const toIdx = list.findIndex(m => m.id === targetId);
            if (fromIdx < 0 || toIdx < 0) return;
            const [moved] = list.splice(fromIdx, 1);
            list.splice(toIdx, 0, moved);
            list.forEach((m, i) => { m.sortOrder = i;
                persistOne(m); });
            list.forEach(m => { const idx = memos.findIndex(x => x.id === m.id); if (idx > -1) memos[idx] = m; });
            renderTable();
        }

        function onRowDragEnd(e) {
            e.currentTarget.style.opacity = '';
            document.querySelectorAll('.drag-over-row').forEach(r => r.classList.remove('drag-over-row'));
            dragId = null;
        }

        // ════════════════════════════════════════════════════════
        //  SORT
        // ════════════════════════════════════════════════════════
        function toggleSort() {
            sortMode = sortMode === 'newest' ? 'oldest' : 'newest';
            document.getElementById('ctSortLabel').textContent = sortMode === 'newest' ? 'Newest First' : 'Oldest First';
            renderTable();
        }

        // ════════════════════════════════════════════════════════
        //  COLUMN HEADER MENU
        // ════════════════════════════════════════════════════════
        let colMenuKey = null;

        function openColMenu(e, key) {
            e.stopPropagation();
            colMenuKey = key;
            const menu = document.getElementById('colMenu');
            const col = cols.find(c => c.key === key);
            menu.innerHTML = `
              <div class="col-menu-item" onclick="hideCol('${key}')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                Hide column
              </div>
              <div class="col-menu-item" onclick="sortByCol('${key}')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="9" y2="18"/></svg>
                Sort by this column
              </div>`;
            const rect = e.target.getBoundingClientRect();
            menu.style.display = 'block';
            menu.style.top = (rect.bottom + 4) + 'px';
            menu.style.left = Math.min(rect.left, window.innerWidth - 170) + 'px';
        }

        function hideCol(key) {
            const c = cols.find(x => x.key === key);
            if (c) c.visible = false;
            saveCols();
            buildTableHead();
            renderTable();
            closeColMenu();
            toast('Column hidden — restore in Settings', 'ok');
        }

        function sortByCol(key) {
            closeColMenu();
            const list = sortedMemos();
            list.sort((a, b) => (a[key] || '').localeCompare(b[key] || ''));
            list.forEach((m, i) => { m.sortOrder = i;
                persistOne(m);
                memos[memos.findIndex(x => x.id === m.id)] = m; });
            renderTable();
        }

        function closeColMenu() {
            document.getElementById('colMenu').style.display = 'none';
            colMenuKey = null;
        }

        // ════════════════════════════════════════════════════════
        //  SETTINGS — THEME
        // ════════════════════════════════════════════════════════
        function setTheme(t) {
            document.body.dataset.theme = t;
            localStorage.setItem('mlTheme', t);
            buildThemeGrid();
            updateMetaTheme();
        }

        function buildThemeGrid() {
            const t = document.body.dataset.theme;
            document.querySelectorAll('.theme-btn').forEach(b => {
                b.classList.toggle('active', b.dataset.themeVal === t);
            });
        }

        function updateMetaTheme() {
            const colors = { ops: '#001F4E', dark: '#0D1525', black: '#000000', modern: '#1E3A8A' };
            document.querySelector('meta[name="theme-color"]').content = colors[document.body.dataset.theme] || '#001F4E';
        }

        // ════════════════════════════════════════════════════════
        //  SETTINGS — COLUMNS
        // ════════════════════════════════════════════════════════
        function saveCols() { localStorage.setItem('mlCols', JSON.stringify(cols)); }

        function buildColMgr() {
            const mgr = document.getElementById('colMgr');
            mgr.innerHTML = cols.map((c, i) => `
              <div class="col-row" data-idx="${i}">
                <span class="col-drag">⠿</span>
                <span class="col-name">${c.label}</span>
                <button class="col-toggle ${c.visible ? 'on' : ''}" onclick="toggleCol(${i})" title="${c.visible ? 'Hide' : 'Show'}"></button>
              </div>`).join('');
        }

        function toggleCol(i) {
            cols[i].visible = !cols[i].visible;
            saveCols();
            buildColMgr();
            if (curCat) { buildTableHead();
                renderTable(); }
        }

        // ════════════════════════════════════════════════════════
        //  DATABASE EXPORT / IMPORT
        // ════════════════════════════════════════════════════════
        function exportJSON() {
            if (!memos.length) { toast('No memos to save', 'err'); return; }
            const payload = { _type: 'MemoLogDB', _version: 2, _exported: new Date().toISOString(), _count: memos.length,
                memos };
            const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `MemoLog_${new Date().toISOString().slice(0,10)}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            toast(`Saved — ${memos.length} memos`, 'ok');
        }

        function exportHTML() {
            if (!memos.length) { toast('No memos to export', 'err'); return; }
            const now = new Date().toLocaleDateString('en-MY', { day: '2-digit', month: 'long', year: 'numeric' });
            const all = allCats();
            const catKeys = Object.keys(all);
            const vc = visibleCols();

            const tableFor = catKey => {
                const list = memos.filter(m => m.cat === catKey);
                if (!list.length) return '<p style="color:#888;padding:12px 16px;font-style:italic">No memos.</p>';
                const rows = list.map((m, i) =>
                    `<tr${i % 2 ? ' style="background:#F9FBFD"' : ''}>
                ${vc.map(c => `<td style="padding:9px 14px;border-bottom:1px solid #E8EEF7;font-size:12px;${c.key === 'ref' ? 'font-weight:700;color:#003580;white-space:nowrap' : 'vertical-align:top'}">${m[c.key] || '—'}</td>`).join('')}
              </tr>`).join('');
                const heads = vc.map(c =>
                    `<th style="background:#001F4E;color:rgba(255,255,255,.7);padding:9px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;">${c.label}</th>`
                    ).join('');
                return `<table style="width:100%;border-collapse:collapse"><thead><tr>${heads}</tr></thead><tbody>${rows}</tbody></table>`;
            };

            const html = `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>MEMO.LOG — ${now}</title>
          <style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:system-ui,sans-serif;background:#F4F7FB;color:#0D1F3C}
          .hdr{background:linear-gradient(135deg,#001F4E,#003580);border-bottom:3px solid #C9A84C;padding:16px 20px;color:#fff}
          .hdr h1{font-size:20px;font-weight:800}.hdr h1 em{color:#C9A84C;font-style:normal}
          .hdr p{font-size:11px;color:rgba(255,255,255,.4);margin-top:3px}
          .body{max-width:1000px;margin:0 auto;padding:20px 14px 60px}
          .sec{background:#fff;border:1px solid #E8EEF7;border-radius:10px;margin-bottom:20px;overflow:hidden}
          .sec-hdr{padding:12px 16px;border-bottom:2px solid #E8EEF7;display:flex;align-items:center;gap:8px}
          .sec-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
          .sec-label{font-size:13px;font-weight:800;letter-spacing:.06em;text-transform:uppercase}
          .foot{text-align:center;font-size:10px;color:#7A93B4;padding:16px;letter-spacing:.08em;text-transform:uppercase}
          </style></head><body>
          <div class="hdr"><h1>MEMO<em>.LOG</em></h1><p>Exported ${now} · ${memos.length} memos · by2100551</p></div>
          <div class="body">
          ${catKeys.map(catKey => `<div class="sec">
            <div class="sec-hdr">
              <div class="sec-dot" style="background:${all[catKey].color || '#666'}"></div>
              <span class="sec-label" style="color:${all[catKey].color || '#666'}">${catKey.toUpperCase()}</span>
              <span style="font-size:11px;color:#7A93B4;margin-left:4px">— ${all[catKey].label} · ${memos.filter(m => m.cat === catKey).length} memos</span>
            </div>
            ${tableFor(catKey)}
          </div>`).join('')}
          </div>
          <div class="foot">memo.log · by2100551 · local reference only</div>
          </body></html>`;

            const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `MemoLog_Export_${new Date().toISOString().slice(0,10)}.html`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            toast('HTML exported', 'ok');
        }

        function openImportModal() { document.getElementById('importStatus').className = 'import-status';
            openModal('importModal'); }

        async function importJSON(file) {
            const st = document.getElementById('importStatus');
            try {
                const data = JSON.parse(await file.text());
                const incoming = Array.isArray(data) ? data : (data.memos || []);
                if (!incoming.length) { st.className = 'import-status err';
                    st.textContent = 'No memos found.'; return; }
                let added = 0,
                    skipped = 0;
                for (const m of incoming) {
                    if (!m.ref || !m.cat) { skipped++; continue; }
                    if (memos.find(x => x.ref === m.ref)) { skipped++; continue; }
                    if (!m.id) m.id = `imp-${Date.now()}-${Math.random().toString(36).slice(2,6)}`;
                    memos.unshift(m);
                    await persistOne(m);
                    added++;
                }
                st.className = 'import-status ok';
                st.textContent = `✓ ${added} imported${skipped ? ', ' + skipped + ' skipped' : ''}`;
                updateCounts();
                updateDbInfo();
                if (added) toast(added + ' memos imported', 'ok');
            } catch (e) {
                st.className = 'import-status err';
                st.textContent = 'Invalid file — use a MemoLog .json backup.';
            }
        }

        // ════════════════════════════════════════════════════════
        //  MODAL HELPERS
        // ════════════════════════════════════════════════════════
        function openModal(id) { document.getElementById(id).classList.add('open'); }

        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        // ════════════════════════════════════════════════════════
        //  COUNTS & DB INFO
        // ════════════════════════════════════════════════════════
        function updateCounts() {
            const all = allCats();
            const counts = {};
            Object.keys(all).forEach(k => counts[k] = 0);
            memos.forEach(m => { if (counts[m.cat] !== undefined) counts[m.cat]++; });
            // Update home cards: built-in + custom cats get shown if they have memos
            const homeCards = document.querySelector('.cat-cards');
            // We keep the static 3 cards for built-in, but we need to update counts
            document.getElementById('cnt-ifs').textContent = counts.ifs || 0;
            document.getElementById('cnt-ops').textContent = counts.ops || 0;
            document.getElementById('cnt-fsoc').textContent = counts.fsoc || 0;
            // For custom categories, we add dynamic cards if they have memos
            // (they'll appear when user creates them)
        }

        function updateDbInfo() {
            const all = allCats();
            const counts = {};
            Object.keys(all).forEach(k => counts[k] = 0);
            memos.forEach(m => { if (counts[m.cat] !== undefined) counts[m.cat]++; });
            const parts = Object.entries(counts).filter(([k, v]) => v > 0)
                .map(([k, v]) => `${k.toUpperCase()}:${v}`);
            const el = document.getElementById('dbInfo');
            if (el) el.textContent = memos.length ? `${memos.length} memos · ${parts.join(' ')}` : 'No memos yet';
        }

        // ════════════════════════════════════════════════════════
        //  TOAST
        // ════════════════════════════════════════════════════════
        let _tt;

        function toast(msg, type = '') {
            const el = document.getElementById('toast');
            el.textContent = msg;
            el.className = 'toast show ' + (type || '');
            clearTimeout(_tt);
            _tt = setTimeout(() => el.className = 'toast', 3000);
        }

        // ════════════════════════════════════════════════════════
        //  SERVICE WORKER (PWA offline support)
        // ════════════════════════════════════════════════════════
        function registerSW() {
            if (!('serviceWorker' in navigator)) return;
            const swCode = `
          const CACHE='memolog-v1';
          const URLS=[
            self.registration.scope,
            'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap',
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js',
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js',
            'https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js',
          ];
          self.addEventListener('install',e=>{e.waitUntil(caches.open(CACHE).then(c=>c.addAll(URLS).catch(()=>{})));self.skipWaiting();});
          self.addEventListener('activate',e=>{e.waitUntil(caches.keys().then(keys=>Promise.all(keys.filter(k=>k!==CACHE).map(k=>caches.delete(k)))));self.clients.claim();});
          self.addEventListener('fetch',e=>{e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request).then(res=>{if(res.ok&&e.request.method==='GET'){const clone=res.clone();caches.open(CACHE).then(c=>c.put(e.request,clone));}return res;}).catch(()=>r||new Response('Offline',{status:503}))));});`;
            const blob = new Blob([swCode], { type: 'application/javascript' });
            const url = URL.createObjectURL(blob);
            navigator.serviceWorker.register(url).catch(() => {});
        }

        // ════════════════════════════════════════════════════════
        //  BOOT
        // ════════════════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', async () => {

            const savedTheme = localStorage.getItem('mlTheme') || 'ops';
            document.body.dataset.theme = savedTheme;
            updateMetaTheme();

            try { await openDB(); } catch (e) { console.warn('IDB unavailable', e); }
            await hydrate();
            updateCounts();
            updateDbInfo();
            buildThemeGrid();

            registerSW();

            document.getElementById('hdrBack').addEventListener('click', () => {
                if (document.getElementById('viewSettings').classList.contains('active')) {
                    if (curCat) {
                        document.getElementById('hdrBack').style.display = 'flex';
                        document.getElementById('hdrSettings').style.display = 'none';
                        document.getElementById('hdrCatLabel').style.display = 'block';
                        showView('viewCat');
                    } else {
                        goHome();
                    }
                } else {
                    goHome();
                }
            });

            document.getElementById('hdrSettings').addEventListener('click', goSettings);

            const dz = document.getElementById('dropZone');
            dz.addEventListener('dragover', e => { e.preventDefault();
                dz.classList.add('drag-over'); });
            dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
            dz.addEventListener('drop', e => {
                e.preventDefault();
                dz.classList.remove('drag-over');
                const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/') || f.type ===
                    'application/pdf');
                if (files.length) processFiles(files);
            });

            document.getElementById('imgInput').addEventListener('change', e => {
                const files = Array.from(e.target.files);
                if (files.length) { processFiles(files);
                    e.target.value = ''; }
            });
            document.getElementById('pdfInput').addEventListener('change', e => {
                const files = Array.from(e.target.files);
                if (files.length) { processFiles(files);
                    e.target.value = ''; }
            });

            const importDrop = document.getElementById('importDrop');
            importDrop.addEventListener('dragover', e => { e.preventDefault();
                importDrop.classList.add('drag-over'); });
            importDrop.addEventListener('dragleave', () => importDrop.classList.remove('drag-over'));
            importDrop.addEventListener('drop', e => {
                e.preventDefault();
                importDrop.classList.remove('drag-over');
                if (e.dataTransfer.files[0]) importJSON(e.dataTransfer.files[0]);
            });
            document.getElementById('importFileInput').addEventListener('change', e => {
                if (e.target.files[0]) { importJSON(e.target.files[0]);
                    e.target.value = ''; }
            });
            document.getElementById('importModal').addEventListener('click', e => {
                if (e.target === document.getElementById('importModal')) closeModal('importModal');
            });
            document.getElementById('addModal').addEventListener('click', e => {
                if (e.target === document.getElementById('addModal')) closeModal('addModal');
            });
            document.getElementById('delModal').addEventListener('click', e => {
                if (e.target === document.getElementById('delModal')) closeModal('delModal');
            });

            document.addEventListener('click', () => closeColMenu());

            window.addEventListener('beforeunload', e => {
                if (pendingSave) {
                    const m = 'Changes are being saved — please wait a moment.';
                    e.preventDefault();
                    e.returnValue = m;
                    return m;
                }
            });

            document.addEventListener('visibilitychange', () => {
                if (document.hidden) showSaveBanner();
            });

            checkFirstOpen();
            updateLinkBtn(!!localStorage.getItem('mlFileLinked'));

            if (localStorage.getItem('mlFileLinked') && !fileHandle && memos.length) {
                setTimeout(() => {
                    if (!fileHandle && fsaSupported) {
                        toast('Tip: Re-link your backup file for auto-save → tap 🔗 Link File', '');
                    }
                }, 2000);
            }

        });
    </script>
