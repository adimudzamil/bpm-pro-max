    <!-- ── MAIN APPLICATION ── -->
    <script>
        'use strict';
        // ════════════════════════════════════════════════════════
        //  CONSTANTS & STATE
        // ════════════════════════════════════════════════════════
        pdfjsLib.GlobalWorkerOptions.workerSrc =
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        const DB_NAME = 'MemoLogDB2';
        const DB_VER = 1;
        const ST_MEMOS = 'memos';
        const ST_META = 'meta';
        let db = null;
        let memos = [];
        let curCat = null;
        let sortMode = 'newest';
        let editingId = null;
        let deleteId = null;

        const DEFAULT_COLS = [
            { key: 'dateIssued', label: 'Date Issued', visible: true, editable: true },
            { key: 'ref', label: 'Ref', visible: true, editable: true },
            { key: 'subject', label: 'Subject', visible: true, editable: true },
            { key: 'effective', label: 'Effective', visible: true, editable: true },
            { key: 'validity', label: 'Validity', visible: true, editable: true },
        ];
        let cols = JSON.parse(localStorage.getItem('mlCols') || 'null') || DEFAULT_COLS;

        // ════════════════════════════════════════════════════════
        //  INDEXEDDB
        // ════════════════════════════════════════════════════════
        function openDB() {
            return new Promise((res, rej) => {
                const r = indexedDB.open(DB_NAME, DB_VER);
                r.onupgradeneeded = e => {
                    const d = e.target.result;
                    if (!d.objectStoreNames.contains(ST_MEMOS)) {
                        const s = d.createObjectStore(ST_MEMOS, { keyPath: 'id' });
                        s.createIndex('cat', 'cat', { unique: false });
                        s.createIndex('ts', 'ts', { unique: false });
                    }
                    if (!d.objectStoreNames.contains(ST_META))
                        d.createObjectStore(ST_META, { keyPath: 'key' });
                };
                r.onsuccess = e => { db = e.target.result;
                    res(); };
                r.onerror = e => rej(e.target.error);
            });
        }

        function tx(store, mode) { return db.transaction(store, mode).objectStore(store); }

        function dbPut(storeName, obj) {
            return new Promise((res, rej) => {
                const r = tx(storeName, 'readwrite').put(obj);
                r.onsuccess = () => res();
                r.onerror = e => rej(e.target.error);
            });
        }

        function dbDelete(id) {
            return new Promise((res, rej) => {
                const r = tx(ST_MEMOS, 'readwrite').delete(id);
                r.onsuccess = () => res();
                r.onerror = e => rej(e.target.error);
            });
        }

        function dbGetAll() {
            return new Promise((res, rej) => {
                const r = tx(ST_MEMOS, 'readonly').getAll();
                r.onsuccess = e => res(e.target.result || []);
                r.onerror = e => rej(e.target.error);
            });
        }

        async function hydrate() {
            try {
                let rows = await dbGetAll();
                if (!rows.length) {
                    const old = localStorage.getItem('mhMemoLog_backup') || localStorage.getItem('mhMemoLog_v4');
                    if (old) {
                        try {
                            const parsed = JSON.parse(old);
                            for (const m of parsed) { await dbPut(ST_MEMOS, m); }
                            rows = await dbGetAll();
                            if (rows.length) toast('Migrated ' + rows.length + ' memos from old storage', 'ok');
                        } catch (e) {}
                    }
                }
                memos = rows;
            } catch (e) {
                try { memos = JSON.parse(localStorage.getItem('mhMemoLog_backup') || '[]'); } catch (e2) { memos = []; }
            }
        }

        // ════════════════════════════════════════════════════════
        //  AUTO-SAVE SYSTEM
        // ════════════════════════════════════════════════════════
        let fileHandle = null;
        let fsaSupported = typeof window !== 'undefined' && 'showSaveFilePicker' in window;
        let autoSaveTimer = null;
        let pendingSave = false;

        function showChip(state, label) {
            const chip = document.getElementById('asChip');
            const dot = document.getElementById('asDot');
            const lbl = document.getElementById('asLabel');
            if (!chip) return;
            dot.className = 'as-dot ' + state;
            lbl.textContent = label;
            chip.classList.add('show');
            if (state === 'saved') {
                clearTimeout(autoSaveTimer);
                autoSaveTimer = setTimeout(() => chip.classList.remove('show'), 3000);
            }
        }

        async function writeToLinkedFile() {
            if (!fileHandle) return false;
            try {
                const writable = await fileHandle.createWritable();
                const payload = { _type: 'MemoLogDB', _version: 2, _exported: new Date().toISOString(), _count: memos
                        .length, memos };
                await writable.write(JSON.stringify(payload, null, 2));
                await writable.close();
                localStorage.setItem('mlLastSaved', new Date().toISOString());
                return true;
            } catch (e) {
                console.warn('Auto-save write failed:', e);
                return false;
            }
        }

        let _asDebounce;

        async function triggerAutoSave() {
            pendingSave = true;
            showChip('saving', 'Saving…');
            clearTimeout(_asDebounce);
            _asDebounce = setTimeout(async () => {
                lsMirror();
                if (fileHandle && fsaSupported) {
                    const ok = await writeToLinkedFile();
                    showChip(ok ? 'saved' : 'err', ok ? 'Auto-saved' : 'Save failed');
                } else {
                    showChip('saved', 'Stored locally');
                }
                pendingSave = false;
            }, 1500);
        }

        async function linkBackupFile() {
            if (!fsaSupported) {
                toast('Auto-save to file not supported on this browser — use Save button instead', 'err');
                return;
            }
            try {
                fileHandle = await window.showSaveFilePicker({
                    suggestedName: 'MemoLog_Database.json',
                    types: [{ description: 'JSON Database', accept: { 'application/json': ['.json'] } }]
                });
                localStorage.setItem('mlFileLinked', 'true');
                updateLinkBtn(true);
                showChip('saving', 'Saving…');
                const ok = await writeToLinkedFile();
                showChip(ok ? 'saved' : 'err', ok ? 'File linked — auto-saving' : 'Link failed');
                toast('File linked — changes will auto-save', 'ok');
            } catch (e) {
                if (e.name !== 'AbortError') toast('Could not link file', 'err');
            }
        }

        function updateLinkBtn(linked) {
            const btn = document.getElementById('linkFileBtn');
            if (!btn) return;
            if (linked) {
                btn.className = 'db-btn link linked';
                btn.title = 'File linked — auto-saving';
                btn.textContent = '✓ Linked';
            } else {
                btn.className = 'db-btn link';
                btn.title = 'Auto-save to a file on your device';
                btn.textContent = '🔗 Link File';
            }
            if (!fsaSupported) btn.style.display = 'none';
        }

        function lsMirror() {
            try { localStorage.setItem('mhMemoLog_backup', JSON.stringify(memos)); } catch (e) {}
        }

        async function persistOne(m) {
            try { await dbPut(ST_MEMOS, m); } catch (e) {}
            triggerAutoSave();
        }

        async function removeOne(id) {
            try { await dbDelete(id); } catch (e) {}
            triggerAutoSave();
        }

        // ════════════════════════════════════════════════════════
        //  FIRST-OPEN FLOW
        // ════════════════════════════════════════════════════════
        function checkFirstOpen() {
            const seen = localStorage.getItem('mlFoSeen');
            if (!seen && memos.length === 0) {
                document.getElementById('foModal').classList.add('open');
            }
        }

        function foSkip() {
            localStorage.setItem('mlFoSeen', '1');
            document.getElementById('foModal').classList.remove('open');
        }

        function foImport() {
            localStorage.setItem('mlFoSeen', '1');
            document.getElementById('foModal').classList.remove('open');
            document.getElementById('importStatus').className = 'import-status';
            openModal('importModal');
        }

        async function foLinkFile() {
            localStorage.setItem('mlFoSeen', '1');
            document.getElementById('foModal').classList.remove('open');
            if (fsaSupported) {
                try {
                    const [handle] = await window.showOpenFilePicker({
                        types: [{ description: 'JSON Database', accept: { 'application/json': ['.json'] } }],
                        multiple: false
                    });
                    const file = await handle.getFile();
                    fileHandle = handle;
                    localStorage.setItem('mlFileLinked', 'true');
                    updateLinkBtn(true);
                    await importJSON(file);
                    toast('File linked and database loaded', 'ok');
                } catch (e) {
                    if (e.name !== 'AbortError') {
                        await linkBackupFile();
                    }
                }
            } else {
                document.getElementById('importStatus').className = 'import-status';
                openModal('importModal');
            }
        }

        // ════════════════════════════════════════════════════════
        //  MOBILE SAVE BANNER
        // ════════════════════════════════════════════════════════
        let bannerDismissed = false;

        function showSaveBanner() {
            if (fileHandle || !memos.length || bannerDismissed) return;
            document.getElementById('saveBanner').classList.add('show');
        }

        function dismissSaveBanner() {
            bannerDismissed = true;
            document.getElementById('saveBanner').classList.remove('show');
        }

        async function saveBackupNow() {
            exportJSON();
            dismissSaveBanner();
        }

        // ════════════════════════════════════════════════════════
        //  PARSING — HELPERS
        // ════════════════════════════════════════════════════════
        const MONTHS =
            'JAN(?:UARY)?|FEB(?:RUARY)?|MAR(?:CH)?|APR(?:IL)?|MAY|JUN(?:E)?|JUL(?:Y)?|AUG(?:UST)?|SEP(?:TEMBER)?|OCT(?:OBER)?|NOV(?:EMBER)?|DEC(?:EMBER)?';
        const MO_IDX = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
        const ALL_CATS = 'FSOC|IFS|OPS|FOTM|FOMM|FOTC|FOPS|FOCC|FOCA|FOCM|DFO|DFT|FOO|FLTOPS';

        function parseDate(s) {
            if (!s) return null;
            s = s.trim();
            const mL = s.match(new RegExp(`(\\d{1,2})(?:st|nd|rd|th)?[\\s]+(${MONTHS})[\\s]+(20\\d{2})`, 'i'));
            if (mL) return `${parseInt(mL[1])} ${mL[2].substring(0,3).toUpperCase()} ${mL[3]}`;
            const m4 = s.match(/(\d{1,2})[\/\-](\d{1,2})[\/\-](20\d{2})/);
            if (m4) { const mo = MO_IDX[parseInt(m4[2]) - 1] || m4[2]; return `${parseInt(m4[1])} ${mo} ${m4[3]}`; }
            const m2 = s.match(/(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2})$/);
            if (m2) { const mo = MO_IDX[parseInt(m2[2]) - 1] || m2[2]; return `${parseInt(m2[1])} ${mo} 20${m2[3]}`; }
            // ── CHANGE 2: added NIL ──
            if (/^(UFN|NIL|N\/A|NA|TBD|IMMEDIATE EFFECT|IMMEDIATE)$/i.test(s)) return s.toUpperCase();
            return null;
        }

        // ════════════════════════════════════════════════════════
        //  CHANGE 1 of 4 — Fix extractRef() NUM and SEP patterns
        // ════════════════════════════════════════════════════════
        function extractRef(text) {
            // SEP between major parts (FO, CAT, NUM, YR)
            const SEP = '[\\s\\/\\-\\.]+';
            // SEP_OPT: separator between NUM and YR is optional
            // because OCR sometimes merges "144-2026" → "1442026"
            const SEP_OPT = '[\\s\\/\\-\\.]*';
            // CAT: any 2-6 letter dept code (case insensitive via 'i' flag)
            const CAT = '([A-Za-z]{2,6})';
            // NUM: 1-4 digits, optional letter suffix (e.g. 088A, 24B)
            // also allow up to 3 digits that run into the year
            const NUM = '(\\d{1,4}[A-Za-z]?)';
            const YR = '(20\\d{2})';

            const lines = text.split(/\n/).map(l => l.trim());

            for (let i = 0; i < lines.length; i++) {
                const line = lines[i];
                // Only look near the REF label — ignore rest of doc
                if (!/\bREF\b/i.test(line)) continue;

                // Check this line and next 2 lines
                const candidates = [
                    line,
                    lines[i + 1] || '',
                    lines[i + 2] || '',
                ];

                for (const candidate of candidates) {
                    // Primary: standard FO/CAT/NUM/YR with any separator
                    const rx = new RegExp(
                        `F[O0]${SEP}${CAT}${SEP}${NUM}${SEP_OPT}${YR}`,
                        'i'
                    );
                    const m = candidate.match(rx);
                    if (m) {
                        const cat = m[1].toUpperCase();
                        const num = m[2].toUpperCase();
                        const yr = m[3];
                        if (num && yr) {
                            const yearN = parseInt(yr);
                            if (yearN >= 2000 && yearN <= 2099) {
                                return `FO/${cat}/${num}/${yr}`;
                            }
                        }
                    }

                    // Fallback: OCR merged NUM and YR into one token
                    // e.g. "FO-IFS-1442026" — split last 4 digits as year
                    const rx2 = new RegExp(
                        `F[O0]${SEP}${CAT}${SEP}(\\d{1,4}[A-Za-z]?)(20\\d{2})`,
                        'i'
                    );
                    const m2 = candidate.match(rx2);
                    if (m2) {
                        const cat = m2[1].toUpperCase();
                        const num = m2[2].toUpperCase();
                        const yr = m2[3];
                        if (num && yr) {
                            const yearN = parseInt(yr);
                            if (yearN >= 2000 && yearN <= 2099) {
                                return `FO/${cat}/${num}/${yr}`;
                            }
                        }
                    }
                }
            }

            return null;
        }

        // ── CUSTOM CATEGORY SYSTEM ─────────────────────────────────────

        // Built-in categories — these always exist
        const BUILTIN_CATS = {
            ifs: { label: 'In-Flight Services', color: '#003580' },
            ops: { label: 'Ops & Flight Ops', color: '#16A34A' },
            fsoc: { label: 'Flight Safety', color: '#DC2626' },
        };

        // Load user-defined dept-to-category mappings from localStorage
        // Format: { "FOTM": "ops", "DFO": "ops", "MYCODE": "training" }
        function loadDeptMap() {
            try { return JSON.parse(localStorage.getItem('mlDeptMap') || '{}'); } catch (e) { return {}; }
        }

        function saveDeptMap(map) {
            localStorage.setItem('mlDeptMap', JSON.stringify(map));
        }

        // Load user-defined custom categories
        // Format: { "training": { label: "Training", color: "#7C3AED" } }
        function loadCustomCats() {
            try { return JSON.parse(localStorage.getItem('mlCustomCats') || '{}'); } catch (e) { return {}; }
        }

        function saveCustomCats(cats) {
            localStorage.setItem('mlCustomCats', JSON.stringify(cats));
        }

        // All categories combined
        function allCats() {
            return { ...BUILTIN_CATS, ...loadCustomCats() };
        }

        // ── CHANGE 3 of 4 — Custom Categories system ──
        function detectCat(ref) {
            if (!ref) return null;
            const parts = ref.toUpperCase().split('/');
            if (parts.length < 4) return null;
            const dept = parts[1];

            // Check user-defined dept map first
            const deptMap = loadDeptMap();
            if (deptMap[dept]) return deptMap[dept];

            // Built-in rules
            if (dept === 'FSOC') return 'fsoc';
            if (dept === 'IFS') return 'ifs';

            // Everything else → ops
            return 'ops';
        }

        // Save a dept-to-category mapping for future auto-routing
        function saveDeptMapping(dept, catKey) {
            const map = loadDeptMap();
            map[dept.toUpperCase()] = catKey;
            saveDeptMap(map);
        }

        // ── END CUSTOM CATEGORY SYSTEM ─────────────────────────────────

        function extractSubject(text) {
            const lines = text.split(/\n/).map(l => l.trim()).filter(Boolean);

            for (let i = 0; i < lines.length; i++) {
                const m = lines[i].match(/^SUBJECT[\s\|\:\-]+(.{4,})/i);
                if (!m) continue;
                const parts = [cleanSubj(m[1])];
                for (let j = i + 1; j < Math.min(i + 8, lines.length); j++) {
                    if (FIELD_BOUNDARY.test(lines[j])) break;
                    const c = cleanSubj(lines[j]);
                    if (isOnlyDash(c)) break;
                    if (!c) continue;
                    parts.push(c);
                }
                const joined = parts.filter(Boolean).join(' ');
                if (okSubj(joined)) return joined;
            }

            for (let i = 0; i < lines.length; i++) {
                if (!/^SUBJECT\s*$/i.test(lines[i])) continue;
                const parts = [];
                for (let j = i + 1; j < Math.min(i + 8, lines.length); j++) {
                    if (FIELD_BOUNDARY.test(lines[j])) break;
                    const c = cleanSubj(lines[j]);
                    if (isOnlyDash(c)) break;
                    if (!c) continue;
                    parts.push(c);
                }
                const joined = parts.filter(Boolean).join(' ');
                if (okSubj(joined)) return joined;
            }

            const meRx = new RegExp(
                `FO[-\\/\\s](${ALL_CATS})[-\\/\\s_]\\d+[-\\/\\s_]\\d+[\\s:\\-–_]+(.{4,})`,
                'i'
            );
            const me = text.match(meRx);
            if (me) {
                const matchIndex = text.indexOf(me[0]);
                const afterMatch = text.slice(matchIndex + me[0].length);
                const nextLineRaw = (afterMatch.split(/\n/)[0] || '').trim();
                const firstPart = cleanSubj(me[2]);
                let combined = firstPart;
                if (nextLineRaw && !FIELD_BOUNDARY.test(nextLineRaw) && !isOnlyDash(nextLineRaw)) {
                    const nextClean = cleanSubj(nextLineRaw);
                    if (nextClean) combined = firstPart + ' ' + nextClean;
                }
                if (okSubj(combined)) return combined;
            }

            return null;
        }

        function extractDateField(text, label) {
            const lines = text.split(/\n/).map(l => l.trim()).filter(Boolean);
            const lRx = new RegExp(`^${label}\\b[\\s\\|\\:]*`, 'i');
            const tRx = new RegExp(`^${label}\\b`, 'i');
            for (let i = 0; i < lines.length; i++) {
                if (!tRx.test(lines[i])) continue;
                const cands = [
                    lines[i].replace(lRx, '').replace(/\s*VALIDITY\b.*/i, ''),
                    lines[i + 1] || '',
                    lines[i + 2] || ''
                ];
                for (const c of cands) {
                    const d = parseDate(c.trim());
                    if (d) return d;
                    const sp = c.match(/\b(UFN|N\/A|TBD|IMMEDIATE EFFECT|IMMEDIATE|NIL)\b/i);
                    if (sp && c.length < 40) return sp[1].toUpperCase();
                }
            }
            return null;
        }

        function extractEffective(text) {
            const lines = text.split(/\n/).map(l => l.trim()).filter(Boolean);
            for (const line of lines) {
                if (!/^EFFECTIVE\b/i.test(line)) continue;
                const s = line.replace(/^EFFECTIVE\b[\s\|:]*/i, '').replace(/\s*VALIDITY\b.*/i, '').trim();
                const d = parseDate(s);
                if (d) return d;
                const sp = s.match(/\b(UFN|N\/A|TBD|IMMEDIATE EFFECT|IMMEDIATE|NIL)\b/i);
                if (sp) return sp[1].toUpperCase();
            }
            return extractDateField(text, 'EFFECTIVE');
        }

        // ── CHANGE 2 (part 2): extractValidity() regex updated ──
        function extractValidity(text) {
            const lines = text.split(/\n/).map(l => l.trim()).filter(Boolean);
            for (const line of lines) {
                if (!/VALIDITY\b/i.test(line)) continue;
                const after = line.replace(/.*?VALIDITY\b[\s\|:]*/i, '').trim();
                const clean = after.split(/\s{2,}|\|/)[0].trim();
                const d = parseDate(clean);
                if (d) return d;
                // ── UPDATED: added NIL, NA ──
                const sp = clean.match(/^(UFN|NIL|NA|N\/A|TBD)\b/i);
                if (sp) return sp[1].toUpperCase();
                const idx = lines.indexOf(line);
                if (lines[idx + 1]) {
                    const d2 = parseDate(lines[idx + 1]);
                    if (d2) return d2;
                    const ns = lines[idx + 1].match(/\b(UFN|NIL|NA|N\/A|TBD)\b/i);
                    if (ns) return ns[1].toUpperCase();
                }
            }
            return extractDateField(text, 'VALIDITY');
        }

        function parseFields(text) {
            const ref = extractRef(text);
            const subject = extractSubject(text);
            const dateIssued = extractDateField(text, 'DATE');
            const effective = extractEffective(text);
            const validity = extractValidity(text);
            return { ref, subject, dateIssued, effective, validity };
        }

        const TABLE_SKIP =
            /^(TO|FROM|REF|DATE|EFFECTIVE|VALIDITY|CATEGORY|LEVEL|INFORMATION|COMPLIANCE|LOW|MEDIUM|HIGH|UFN|N\/A|TBD|ALL CREW|ALL FLIGHT|ALL CREWMEMBERS|HEAD|CHIEF|SENIOR|CAPTAIN|INTRODUCTION|INSTRUCTIONS|MANUAL INCORPORATION|ISSUED|INTERNAL|DEAR|FOR YOUR|N\/A)$/i;

        function okSubj(s) { return s && s.length > 6 && !TABLE_SKIP.test(s.trim()) && !/^\d+$/.test(s.trim()); }

        const FIELD_BOUNDARY =
            /^(TO|FROM|REF|DATE\b|EFFECTIVE\b|VALIDITY\b|CATEGORY\b|LEVEL\b|INFORMATION\b|COMPLIANCE\b|INTRODUCTION\b|INSTRUCTIONS\b|MANUAL\s+INCORPORATION\b|ISSUED\b|INTERNAL\b|DEAR\b|BACKGROUND\b|ACTION\b|ATTACHMENT\b|DISTRIBUTION\b|PREPARED\b|APPROVED\b|SIGNED\b|REFERENCE\b)/i;

        function isOnlyDash(s) { return /^[\-–—=\*\s]+$/.test(s); }

        function cleanSubj(s) {
            return s
                .replace(/^[\s\-–—:]+/, '')
                .replace(/[\s\-–—:]+$/, '')
                .replace(/\s{2,}/g, ' ')
                .trim()
                .toUpperCase();
        }

        function refSortKey(ref) {
            if (!ref) return { year: 0, num: 0 };
            const m = ref.match(/\/(\d{1,4})\/(20\d{2})$/);
            return m ? { year: parseInt(m[2]), num: parseInt(m[1]) } : { year: 0, num: 0 };
        }

        // ── PART 1: waitForTesseract + ocrFile ──────────────────────────

        function waitForTesseract(maxMs = 15000) {
            return new Promise((resolve, reject) => {
                if (typeof Tesseract !== 'undefined') {
                    resolve();
                    return;
                }
                const start = Date.now();
                const check = setInterval(() => {
                    if (typeof Tesseract !== 'undefined') {
                        clearInterval(check);
                        resolve();
                    } else if (Date.now() - start > maxMs) {
                        clearInterval(check);
                        reject(new Error(
                            'Tesseract did not load in time. Check your internet connection and try again.'));
                    }
                }, 200);
            });
        }

        async function ocrFile(fileOrBlob) {
            // Show loading indicator
            const loadingEl = document.getElementById('tessLoading');
            if (loadingEl) loadingEl.classList.add('show');

            try {
                await waitForTesseract();
            } catch (err) {
                if (loadingEl) loadingEl.classList.remove('show');
                throw err;
            }

            if (loadingEl) loadingEl.classList.remove('show');

            const url = URL.createObjectURL(fileOrBlob);
            try {
                const result = await Tesseract.recognize(url, 'eng', { logger: () => {} });
                return result.data.text;
            } finally {
                URL.revokeObjectURL(url);
            }
        }

        // ── PDF helpers ──────────────────────────────────────────────────

        async function pdfToText(file) {
            const ab = await file.arrayBuffer();
            const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
            let out = '';
            for (let p = 1; p <= Math.min(pdf.numPages, 2); p++) {
                const page = await pdf.getPage(p);
                const cont = await page.getTextContent();
                let lastY = null;
                const parts = [];
                for (const item of cont.items) {
                    if (lastY !== null && Math.abs(item.transform[5] - lastY) > 4) parts.push('\n');
                    parts.push(item.str);
                    lastY = item.transform[5];
                }
                out += parts.join(' ') + '\n';
            }
            return out;
        }

        async function pdfToImageBlob(file) {
            const ab = await file.arrayBuffer();
            const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
            const page = await pdf.getPage(1);
            const vp = page.getViewport({ scale: 2 });
            const cvs = document.createElement('canvas');
            cvs.width = vp.width;
            cvs.height = vp.height;
            await page.render({ canvasContext: cvs.getContext('2d'), viewport: vp }).promise;
            return new Promise(r => cvs.toBlob(b => r(b), 'image/jpeg', 0.9));
        }

        // ── processFiles with friendly error handling ──────────────────

        async function processFiles(files) {
            if (!files.length) return;
            const procWrap = document.getElementById('procWrap');
            const procBar = document.getElementById('procBar');
            const procLabel = document.getElementById('procLabel');
            const procPct = document.getElementById('procPct');
            const parseLog = document.getElementById('parseLog');
            const plRows = document.getElementById('plRows');

            procWrap.classList.add('show');
            parseLog.classList.add('show');

            let added = 0,
                failed = 0;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const pct = Math.round((i / files.length) * 100);
                procBar.style.width = pct + '%';
                procLabel.textContent = `${i+1} / ${files.length}: ${file.name.substring(0,30)}`;
                procPct.textContent = pct + '%';

                try {
                    let text = '';
                    if (file.type === 'application/pdf') {
                        text = await pdfToText(file);
                        if (!extractRef(text)) {
                            const blob = await pdfToImageBlob(file);
                            text = await ocrFile(blob);
                        }
                    } else {
                        text = await ocrFile(file);
                    }

                    const f = parseFields(text);

                    if (!f.ref) {
                        addLogRow('fail', file.name, 'REF not found');
                        failed++;
                        continue;
                    }

                    if (memos.find(m => m.ref === f.ref)) {
                        addLogRow('fail', file.name, `${f.ref} already in log`);
                        continue;
                    }

                    const cat = detectCat(f.ref);
                    if (!cat) {
                        addLogRow('fail', file.name, `Unknown category: ${f.ref}`);
                        failed++;
                        continue;
                    }

                    const memo = {
                        id: `${Date.now()}-${Math.random().toString(36).slice(2,6)}`,
                        cat,
                        ref: f.ref,
                        subject: f.subject || '—',
                        dateIssued: f.dateIssued || '—',
                        effective: f.effective || '—',
                        validity: f.validity || '—',
                        sortOrder: 0,
                        ts: new Date().toISOString()
                    };

                    memos.unshift(memo);
                    await persistOne(memo);
                    addLogRow('ok', file.name, f.ref, f.subject || '');
                    added++;

                } catch (err) {
                    const msg = err.message || String(err);
                    if (msg.toLowerCase().includes('tesseract') || msg.toLowerCase().includes('not defined') ||
                        msg.toLowerCase().includes('load in time')) {
                        addLogRow('fail', file.name, 'OCR not ready — wait a moment and try again');
                        toast('Tesseract still loading — try again in a few seconds', 'err');
                    } else {
                        addLogRow('fail', file.name, 'Error: ' + msg);
                    }
                    failed++;
                }
            }

            procBar.style.width = '100%';
            procPct.textContent = '100%';
            procLabel.textContent = `Done — ${added} added, ${failed} failed`;

            updateCounts();
            if (curCat) renderTable();
            updateDbInfo();

            if (added) toast(`${added} memo${added > 1 ? 's' : ''} added`, 'ok');
            if (failed) toast(`${failed} file${failed > 1 ? 's' : ''} failed`, 'err');
        }

        function addLogRow(type, filename, refOrMsg, subject) {
            const plRows = document.getElementById('plRows');
            const div = document.createElement('div');
            div.className = 'pl-row ' + type;
            div.innerHTML = type === 'ok' ?
                `<span class="pl-icon">✓</span><span class="pl-text"><span class="pl-ref">${refOrMsg}</span>${subject ? ' — ' + subject.substring(0,60) : ''}</span>` :
                `<span class="pl-icon">✗</span><span class="pl-text"><strong>${filename.substring(0,24)}</strong> — ${refOrMsg}</span>`;
            plRows.appendChild(div);
            plRows.scrollTop = plRows.scrollHeight;
        }

