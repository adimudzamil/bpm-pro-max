        function regenerateAllCharts() {
            generateSeatRows('topSeatContainer', currentRowCount);
            generateSeatRows('bottomSeatContainer', currentRowCount);
            if (topChartData) populateChart('top', topChartData);
            if (bottomChartData) populateChart('bottom', bottomChartData);
            if (isAftView) {
                applyAftViewToContainer('topSeatContainer', true);
                applyAftViewToContainer('bottomSeatContainer', true);
            }
        }
        
        function toggleRow4Mode() {
            const row4Toggle = document.getElementById('row4Toggle');
            const newRowCount = row4Toggle.checked ? 4 : 3;
            // Persist setting
            localStorage.setItem('scUIRow4', row4Toggle.checked ? 'true' : 'false');
            if (newRowCount === currentRowCount) return;
            currentRowCount = newRowCount;
            regenerateAllCharts();
            let hiddenPassengersTop = 0;
            let hiddenPassengersBottom = 0;
            if (topChartData && topChartData.passengers) {
                hiddenPassengersTop = topChartData.passengers.filter(p => {
                    const rowNum = parseInt(p.seat.match(/\d+/)[0]);
                    return rowNum === 4;
                }).length;
            }
            if (bottomChartData && bottomChartData.passengers) {
                hiddenPassengersBottom = bottomChartData.passengers.filter(p => {
                    const rowNum = parseInt(p.seat.match(/\d+/)[0]);
                    return rowNum === 4;
                }).length;
            }
            if ((hiddenPassengersTop > 0 || hiddenPassengersBottom > 0) && currentRowCount === 3) {
                const warningMsg = `⚠️ ${hiddenPassengersTop + hiddenPassengersBottom} passenger(s) in row 4 not shown (3-row mode active)`;
                if (topChartData && document.getElementById('topZoneSummary')) {
                    let oldText = document.getElementById('topZoneSummary').innerHTML;
                    document.getElementById('topZoneSummary').innerHTML = oldText + `<span class="warning-message">${warningMsg}</span>`;
                }
                if (bottomChartData && document.getElementById('bottomZoneSummary')) {
                    let oldText = document.getElementById('bottomZoneSummary').innerHTML;
                    document.getElementById('bottomZoneSummary').innerHTML = oldText + `<span class="warning-message">${warningMsg}</span>`;
                }
                setTimeout(() => {
                    if (document.getElementById('topZoneSummary')) {
                        document.getElementById('topZoneSummary').innerHTML = document.getElementById('topZoneSummary').innerHTML.replace(`<span class="warning-message">${warningMsg}</span>`, '');
                    }
                    if (document.getElementById('bottomZoneSummary')) {
                        document.getElementById('bottomZoneSummary').innerHTML = document.getElementById('bottomZoneSummary').innerHTML.replace(`<span class="warning-message">${warningMsg}</span>`, '');
                    }
                }, 5000);
            }
        }
        
        function applyAftViewToContainer(containerId, apply) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const rows = Array.from(container.querySelectorAll('.row'));
            if (apply) {
                rows.reverse().forEach(row => { container.appendChild(row); });
                rows.forEach(row => {
                    row.classList.add('aft-view');
                    const seatA = row.querySelector(`[data-seat$="A"]`);
                    const seatC = row.querySelector(`[data-seat$="C"]`);
                    const seatD = row.querySelector(`[data-seat$="D"]`);
                    const seatF = row.querySelector(`[data-seat$="F"]`);
                    const gaps = row.querySelectorAll('.gap');
                    const aisles = row.querySelectorAll('.aisle');
                    if (!seatA || !seatC || !seatD || !seatF) return;
                    row.innerHTML = '';
                    if (seatF) row.appendChild(seatF);
                    if (gaps[1]) row.appendChild(gaps[1]);
                    if (seatD) row.appendChild(seatD);
                    if (aisles[0]) row.appendChild(aisles[0]);
                    if (seatC) row.appendChild(seatC);
                    if (gaps[0]) row.appendChild(gaps[0]);
                    if (seatA) row.appendChild(seatA);
                });
            } else {
                rows.sort((a, b) => {
                    const seatA = a.querySelector('.seat-box');
                    const seatB = b.querySelector('.seat-box');
                    const rowNumA = seatA ? parseInt(seatA.dataset.seat.match(/\d+/)[0]) : 0;
                    const rowNumB = seatB ? parseInt(seatB.dataset.seat.match(/\d+/)[0]) : 0;
                    return rowNumA - rowNumB;
                }).forEach(row => { container.appendChild(row); });
                rows.forEach(row => {
                    row.classList.remove('aft-view');
                    const seatA = row.querySelector(`[data-seat$="A"]`);
                    const seatC = row.querySelector(`[data-seat$="C"]`);
                    const seatD = row.querySelector(`[data-seat$="D"]`);
                    const seatF = row.querySelector(`[data-seat$="F"]`);
                    const gaps = row.querySelectorAll('.gap');
                    const aisles = row.querySelectorAll('.aisle');
                    if (!seatA || !seatC || !seatD || !seatF) return;
                    row.innerHTML = '';
                    if (seatA) row.appendChild(seatA);
                    if (gaps[0]) row.appendChild(gaps[0]);
                    if (seatC) row.appendChild(seatC);
                    if (aisles[0]) row.appendChild(aisles[0]);
                    if (seatD) row.appendChild(seatD);
                    if (gaps[1]) row.appendChild(gaps[1]);
                    if (seatF) row.appendChild(seatF);
                });
            }
        }
        
        function toggleAftView() {
            const toggle = document.getElementById('aftViewToggle');
            isAftView = toggle.checked;
            // Persist setting
            localStorage.setItem('scUIAftView', isAftView ? 'true' : 'false');
            applyAftViewToContainer('topSeatContainer', isAftView);
            applyAftViewToContainer('bottomSeatContainer', isAftView);
            adjustFontSize(currentFontSize);
        }
        
        function adjustFontSize(fontSize) {
            currentFontSize = fontSize;
            // Persist setting
            localStorage.setItem('scUIFontSize', fontSize);
            document.getElementById('fontSizeValue').textContent = fontSize + 'px';
            document.body.style.fontSize = fontSize + 'px';
            const scale = fontSize / 12;
            document.querySelectorAll('.seat-box').forEach(box => {
                box.style.minHeight = (55 * scale) + 'px';
                const nameLines = box.querySelectorAll('.name-line');
                nameLines.forEach(line => {
                    line.style.height = (14 * scale) + 'px';
                    line.style.lineHeight = (12 * scale) + 'px';
                    line.style.padding = (1 * scale) + 'px 4px';
                    line.style.fontSize = (1 * fontSize) + 'px';
                });
                const fieldLines = box.querySelectorAll('.field-line');
                fieldLines.forEach(line => {
                    line.style.height = (14 * scale) + 'px';
                    line.style.lineHeight = (12 * scale) + 'px';
                    line.style.padding = (1 * scale) + 'px 4px';
                    if (line.classList.contains('meal-line')) {
                        line.style.fontSize = (1.1 * fontSize) + 'px';
                    } else {
                        line.style.fontSize = (1 * fontSize) + 'px';
                    }
                });
                const seatNumberContainer = box.querySelector('.seat-number-container');
                if (seatNumberContainer) {
                    seatNumberContainer.style.padding = (2 * scale) + 'px ' + (4 * scale) + 'px';
                    const seatNumber = seatNumberContainer.querySelector('.seat-number');
                    if (seatNumber) {
                        seatNumber.style.fontSize = (1.1 * fontSize) + 'px';
                    }
                }
            });
            document.querySelectorAll('.row').forEach(row => {
                row.style.marginBottom = (4 * scale) + 'px';
            });
        }
        
        function parsePassengerName(fullName) {
            if (!fullName || !fullName.includes('/')) {
                return { firstName: '', lastName: '' };
            }
            const parts = fullName.split('/');
            const lastName = parts[0] || '';
            const firstName = parts[1] || '';
            return { firstName, lastName };
        }
        
        function truncateIntelligently(text, maxLength = 25) {
            if (!text || text.length <= maxLength) return text;
            const truncated = text.substring(0, maxLength);
            const lastSpace = truncated.lastIndexOf(' ');
            if (lastSpace > maxLength * 0.7 && lastSpace > 0) {
                return text.substring(0, lastSpace);
            }
            return truncated + '…';
        }
        
        function normalizeSeatNumber(seat) {
            if (!seat) return '';
            return seat.replace(/^0+(\d+)/, '$1');
        }
        
        function populateSeatData(passenger, seatBox) {
            if (!passenger || !seatBox) return;
            const normalizedSeat = normalizeSeatNumber(passenger.seat);
            const { firstName, lastName } = parsePassengerName(passenger.name);
            const title = passenger.title || '';
            clearTierClasses(seatBox);
            let seatNumberHTML = normalizedSeat;
            const DISPLAYED_TIERS = ['EMER', 'PLAT'];
            if (passenger.tier && DISPLAYED_TIERS.includes(passenger.tier)) {
                seatNumberHTML += ` <span class="tier tier-${passenger.tier}">*${passenger.tier}*</span>`;
                seatBox.classList.add('tier-' + passenger.tier);
                seatBox.classList.remove('empty-seat');
            }
            const seatNumberEl = seatBox.querySelector('.seat-number');
            if (seatNumberEl) seatNumberEl.innerHTML = seatNumberHTML;
            const titleLine = seatBox.querySelector('.name-line.title-line');
            if (titleLine) titleLine.textContent = title.toUpperCase() || '';
            const surnameLine = seatBox.querySelector('.name-line.surname-line');
            if (surnameLine) surnameLine.textContent = truncateIntelligently(lastName, 25).toUpperCase() || '';
            const firstNameLine = seatBox.querySelector('.name-line.firstname-line');
            if (firstNameLine) firstNameLine.textContent = truncateIntelligently(firstName, 25).toUpperCase() || '';
            const mealField = seatBox.querySelector('.field-line.meal-line');
            if (mealField) {
                const mealCode = (passenger.meal || '').trim().toUpperCase();
                const specialLabel = getSpecialLabel(passenger);
                let innerHTML = '';
                if (mealCode) innerHTML += '<span class="meal-code-part" data-meal-code="' + mealCode + '">' + mealCode + '</span>';
                if (mealCode && specialLabel) innerHTML += '<span class="meal-sep"> | </span>';
                if (specialLabel) innerHTML += '<span class="special-code-part" data-special-code="' + specialLabel + '">' + specialLabel + '</span>';
                mealField.innerHTML = innerHTML;
                mealField.style.backgroundColor = '';
                mealField.style.color = '';
                if (innerHTML) applyMealLineColors(mealField);
            }
            refreshSeatOrderOverlay(seatBox);
            seatBox.classList.remove('empty-seat');
            seatBox.querySelectorAll('.name-line, .field-line').forEach(line => { line.style.color = ''; });
            if (surnameLine) surnameLine.style.setProperty('--placeholder-content', 'none');
            if (firstNameLine) firstNameLine.style.setProperty('--placeholder-content', 'none');
            if (mealField) mealField.style.setProperty('--placeholder-content', 'none');
        }
        
        function markSeatAsEmpty(seatBox) {
            if (!seatBox) return;
            clearTierClasses(seatBox);
            seatBox.classList.add('empty-seat');
            const seatNumberEl = seatBox.querySelector('.seat-number');
            if (seatNumberEl) seatNumberEl.innerHTML = seatBox.getAttribute('data-seat');
            seatBox.querySelectorAll('.name-line, .field-line').forEach(line => { line.style.color = 'transparent'; });
            const surnameLine = seatBox.querySelector('.name-line.surname-line');
            const firstNameLine = seatBox.querySelector('.name-line.firstname-line');
            const mealLine = seatBox.querySelector('.field-line.meal-line');
            if (surnameLine) { surnameLine.textContent = ''; surnameLine.style.setProperty('--placeholder-content', '"______"'); }
            if (firstNameLine) { firstNameLine.textContent = ''; firstNameLine.style.setProperty('--placeholder-content', '"______"'); }
            if (mealLine) {
                mealLine.innerHTML = '';
                mealLine.style.setProperty('--placeholder-content', '"______"');
                mealLine.style.backgroundColor = '';
                mealLine.style.color = '';
            }
            const titleLine = seatBox.querySelector('.name-line.title-line');
            if (titleLine) titleLine.textContent = '';
        }
        
        function populateChart(chartPosition, chartData) {
            const prefix = chartPosition === 'top' ? 'top' : 'bottom';
            if (chartPosition === 'top') { topChartData = chartData; } else { bottomChartData = chartData; }
            if (!chartData.mealMenu) chartData.mealMenu = [];
            const flightInfo = chartData.flightInfo;
            if (flightInfo) {
                document.getElementById(`${prefix}HeaderTitle`).textContent = 
                    `${flightInfo.flightNumber} | ${flightInfo.sector} | ${flightInfo.date} ${flightInfo.stdLocal} | ${flightInfo.aircraft}`;
            }
            const zoneSummary = chartData.zoneSummary;
            if (zoneSummary) {
                let summaryText = `Business Class: ${zoneSummary.totalPassengers} passengers`;
                if (zoneSummary.specialMeals > 0) summaryText += ` | Special Meals: ${zoneSummary.specialMeals}`;
                if (zoneSummary.emerPlat > 0) summaryText += ` | EMER/PLAT: ${zoneSummary.emerPlat}`;
                if (zoneSummary.mealBreakdown) summaryText += ` | ${zoneSummary.mealBreakdown}`;
                if (zoneSummary.bbml > 0) summaryText += ` | BBML: ${zoneSummary.bbml}`;
                const zoneSummaryEl = document.getElementById(`${prefix}ZoneSummary`);
                if (zoneSummaryEl) zoneSummaryEl.textContent = summaryText;
            }
            const passengers = chartData.passengers || [];
            const occupiedSeats = new Set();
            const container = document.getElementById(`${prefix}SeatContainer`);
            passengers.forEach(passenger => {
                if (!passenger.seat) return;
                const normalizedSeat = normalizeSeatNumber(passenger.seat);
                const seatBox = container.querySelector(`[data-seat="${normalizedSeat}"]`);
                if (seatBox) {
                    populateSeatData(passenger, seatBox);
                    occupiedSeats.add(normalizedSeat);
                }
            });
            const allSeatBoxes = container.querySelectorAll('.seat-box');
            allSeatBoxes.forEach(seatBox => {
                const seatNumber = seatBox.getAttribute('data-seat');
                if (!occupiedSeats.has(seatNumber)) {
                    markSeatAsEmpty(seatBox);
                }
            });
            renderSummaryChips(prefix);
            renderMealCountSummary(prefix);
            console.log(`Loaded ${passengers.length} passengers for ${chartPosition} chart`);
        }
        
        function handlePrint() {
            const orientationSelect = document.getElementById('orientationSelect');
            const isLandscape = orientationSelect.value === 'landscape';
            if (isLandscape) { document.body.classList.add('landscape-print'); } else { document.body.classList.remove('landscape-print'); }
            document.documentElement.style.setProperty('--print-font-size', currentFontSize + 'px');
            setTimeout(() => {
                window.print();
                setTimeout(() => { document.body.classList.remove('landscape-print'); }, 100);
            }, 100);
        }
        
        window.addEventListener('message', function(event) {
            if (event.data && event.data.type === 'loadBottomChart') {
                const dataKey = event.data.dataKey;
                if (dataKey) {
                    const chartData = JSON.parse(localStorage.getItem(dataKey));
                    if (chartData) {
                        populateChart('bottom', chartData);
                        localStorage.removeItem(dataKey);
                        persistChartState();
                    }
                }
            }
        });

        // ============== PERSISTENCE FIXES ==============
        function stateKey() {
            return currentTabId ? ('bpmSeatChartState_' + currentTabId) : null;
        }

        function persistChartState() {
            const key = stateKey();
            if (!key) return;
            try {
                localStorage.setItem(key, JSON.stringify({ top: topChartData, bottom: bottomChartData, savedAt: Date.now() }));
            } catch (e) { console.error('Persist failed', e); }
        }

        function loadPersistedState() {
            const key = stateKey();
            if (!key) return false;
            try {
                const raw = localStorage.getItem(key);
                if (!raw) return false;
                const saved = JSON.parse(raw);
                if (saved.top) populateChart('top', saved.top);
                if (saved.bottom) populateChart('bottom', saved.bottom);
                return true;
            } catch (e) { console.error('Restore failed', e); return false; }
        }

        function loadInitialData() {
            const urlParams = new URLSearchParams(window.location.search);
            const urlTabId = urlParams.get('tabId');
            if (urlTabId) {
                currentTabId = urlTabId;
                localStorage.setItem(LAST_TAB_ID_KEY, urlTabId);
            } else {
                currentTabId = localStorage.getItem(LAST_TAB_ID_KEY) || null;
            }

            const restored = loadPersistedState();
            if (restored) {
                showToast('\u2713 Restored your saved seat chart');
                return;
            }

            const dataKey = urlParams.get('data');
            const chartType = urlParams.get('chart') || 'top';
            if (dataKey && chartType === 'top') {
                const chartData = JSON.parse(localStorage.getItem(dataKey));
                if (chartData) {
                    if (!currentTabId && chartData.tabId) {
                        currentTabId = chartData.tabId;
                        localStorage.setItem(LAST_TAB_ID_KEY, currentTabId);
                    }
                    populateChart('top', chartData);
                    localStorage.removeItem(dataKey);
                    persistChartState();
                }
            }
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            // 1. Load Theme & apply
            loadTheme();
            applyTheme();

            // 2. Load Persisted UI Settings (Font, Aft, Row4) before generating rows
            const savedFont = parseInt(localStorage.getItem('scUIFontSize')) || 12;
            const savedAft = localStorage.getItem('scUIAftView') === 'true';
            const savedRow4 = localStorage.getItem('scUIRow4') !== 'false'; // Default to 4 rows
            currentFontSize = savedFont;
            isAftView = savedAft;
            currentRowCount = savedRow4 ? 4 : 3;

            // 3. Apply UI settings to DOM
            document.getElementById('fontSizeSlider').value = savedFont;
            document.getElementById('aftViewToggle').checked = savedAft;
            document.getElementById('row4Toggle').checked = savedRow4;

            // 4. Generate rows with the correct settings
            generateSeatRows('topSeatContainer', currentRowCount);
            generateSeatRows('bottomSeatContainer', currentRowCount);
            
            // 5. Apply the attached settings
            adjustFontSize(currentFontSize);
            if (isAftView) {
                applyAftViewToContainer('topSeatContainer', true);
                applyAftViewToContainer('bottomSeatContainer', true);
            }

            // 6. Listen for slider changes to save persistent states
            const fontSizeSlider = document.getElementById('fontSizeSlider');
            fontSizeSlider.addEventListener('input', function(e) { adjustFontSize(parseInt(e.target.value)); });

            // 7. Load chart data
            loadInitialData();
            if (window.opener) {
                window.opener.postMessage({ type: 'chartReady' }, '*');
            }
        });
    </script>
</body>
