            if (!theme.orderColors[choiceId]) theme.orderColors[choiceId] = { bg: '#ffffff', text: '#000000' };
            theme.orderColors[choiceId][prop] = val;
            saveTheme();
            applyTheme();
        }

        function closeColorPanel() { document.getElementById('colorPanelOverlay').style.display = 'none'; }

        // ============== INFO EDIT MODAL ==============
        const TITLE_OPTIONS = ['MR','MS','MRS','MISS','MSTR','DATO','DATIN','DTUK','TSRI','MDM','DR','PROF'];
        const TIER_OPTIONS = ['','ELIT','PLAT','GOLD','RUBY','SLVR','BLUE','SAPH','EMER'];

        function sectionForBox(seatBox) {
            return seatBox.closest('#topSeatContainer') ? 'top' : 'bottom';
        }

        function dataForSection(section) {
            return section === 'top' ? topChartData : bottomChartData;
        }

        function openInfoEditModal(seatBox) {
            const seat = seatBox.getAttribute('data-seat');
            const section = sectionForBox(seatBox);
            let data = dataForSection(section);
            if (!data) { showToast('No manifest loaded for this chart yet'); return; }
            if (!data.passengers) data.passengers = [];
            let p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) p = { seat: seat, title: '', name: '', meal: '', tier: '', specialCode: '', specialOtherText: '', isInfant: false, extSeatbelt: false, remarksText: '' };
            const nameParts = parsePassengerName(p.name || '');

            let specialOptionsHTML = '<option value="">— None —</option>';
            SPECIAL_CODES.forEach(function (code) {
                specialOptionsHTML += '<option value="' + code + '"' + (p.specialCode === code ? ' selected' : '') + '>' + code + '</option>';
            });
            specialOptionsHTML += '<option value="OTHERS"' + (p.specialCode === 'OTHERS' ? ' selected' : '') + '>Others</option>';
            const othersDisplay = p.specialCode === 'OTHERS' ? 'block' : 'none';

            let html = '<div class="edit-modal-title">Edit ' + seat + '</div>';
            html += '<label>Title</label><select id="editTitle"><option value="">-</option>' + TITLE_OPTIONS.map(function (t) { return '<option value="' + t + '"' + (p.title === t ? ' selected' : '') + '>' + t + '</option>'; }).join('') + '</select>';
            html += '<label>Surname</label><input type="text" id="editSurname" value="' + (nameParts.lastName || '').replace(/"/g, '&quot;') + '">';
            html += '<label>First name</label><input type="text" id="editFirstname" value="' + (nameParts.firstName || '').replace(/"/g, '&quot;') + '">';
            html += '<label>Meal code</label><input type="text" id="editMeal" value="' + (p.meal || '') + '" placeholder="e.g. VGML">';
            html += '<label>Tier</label><select id="editTier">' + TIER_OPTIONS.map(function (t) { return '<option value="' + t + '"' + (p.tier === t ? ' selected' : '') + '>' + (t || 'None') + '</option>'; }).join('') + '</select>';
            html += '<label>Special</label><select id="editSpecial" onchange="toggleEditOthersInput(this)">' + specialOptionsHTML + '</select>';
            html += '<input type="text" id="editSpecialOther" style="display:' + othersDisplay + ';margin-top:6px;" placeholder="Enter special handling code" value="' + (p.specialOtherText || '').replace(/"/g, '&quot;') + '">';
            html += '<div class="edit-toggle-row"><label class="toggle-switch"><input type="checkbox" id="editInfant" ' + (p.isInfant ? 'checked' : '') + '><span class="toggle-slider"></span></label><span class="edit-toggle-label">INF (Infant)</span></div>';
            html += '<div class="edit-toggle-row"><label class="toggle-switch"><input type="checkbox" id="editExtSeatbelt" ' + (p.extSeatbelt ? 'checked' : '') + '><span class="toggle-slider"></span></label><span class="edit-toggle-label">EXT (Extension Seatbelt)</span></div>';
            html += '<label>Remarks</label><textarea id="editRemarks" rows="2" placeholder="Add remarks...">' + (p.remarksText || '') + '</textarea>';
            html += '<div class="edit-modal-buttons"><button onclick="closeInfoEditModal()">Cancel</button><button onclick="saveInfoEdit(\'' + section + '\',\'' + seat + '\')">Save</button></div>';

            document.getElementById('infoEditBody').innerHTML = html;
            document.getElementById('infoEditOverlay').style.display = 'flex';
        }

        function toggleEditOthersInput(selectEl) {
            const input = document.getElementById('editSpecialOther');
            if (input) input.style.display = selectEl.value === 'OTHERS' ? 'block' : 'none';
        }

        function saveInfoEdit(section, seat) {
            const data = dataForSection(section);
            if (!data) return;
            if (!data.passengers) data.passengers = [];
            let p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) { p = { seat: seat }; data.passengers.push(p); }

            const title = document.getElementById('editTitle').value;
            const surname = document.getElementById('editSurname').value.trim();
            const firstname = document.getElementById('editFirstname').value.trim();
            p.title = title;
            p.name = surname + '/' + firstname;
            p.meal = document.getElementById('editMeal').value.trim().toUpperCase();
            p.tier = document.getElementById('editTier').value;
            p.specialCode = document.getElementById('editSpecial').value;
            p.specialOtherText = document.getElementById('editSpecialOther').value.trim();
            p.isInfant = document.getElementById('editInfant').checked;
            p.extSeatbelt = document.getElementById('editExtSeatbelt').checked;
            p.remarksText = document.getElementById('editRemarks').value;
            p.seat = seat;

            const containerId = section + 'SeatContainer';
            const seatBox = document.querySelector('#' + containerId + ' [data-seat="' + seat + '"]');
            if (seatBox) {
                clearTierClasses(seatBox);
                seatBox.classList.remove('empty-seat');
                populateSeatData(p, seatBox);
                const hasAnyData = p.title || p.name.replace('/', '') || p.meal || p.tier || p.specialCode || p.isInfant || p.extSeatbelt || (p.remarksText && p.remarksText.trim());
                if (!hasAnyData) markSeatAsEmpty(seatBox);
            }

            closeInfoEditModal();
            syncBackToMainPage();
            persistChartState();
            renderSummaryChips(section);
            showToast('Saved ' + seat);
        }

        function closeInfoEditModal() { document.getElementById('infoEditOverlay').style.display = 'none'; }

        // ============== ORDER MODE: MULTI-SERVICE MEAL ORDERS ==============
        let activeOrderSection = 'top';
        let activeServiceId = { top: null, bottom: null };

        function getMealServices(section) {
            const data = dataForSection(section);
            if (!data) return [];
            if (!data.mealServices) data.mealServices = [];
            if (data.mealMenu && data.mealMenu.length && data.mealServices.length === 0) {
                const migratedId = 'service_' + Date.now();
                data.mealServices.push({ id: migratedId, label: 'Meal Service 1', menu: data.mealMenu });
                if (data.passengers) {
                    data.passengers.forEach(function (p) {
                        if (p.orderChoiceId) {
                            p.orders = p.orders || {};
                            p.orders[migratedId] = { choiceId: p.orderChoiceId, served: false };
                            delete p.orderChoiceId;
                        }
                    });
                }
                delete data.mealMenu;
            }
            return data.mealServices;
        }

        function getActiveService(section) {
            const services = getMealServices(section);
            if (services.length === 0) return null;
            let svc = services.find(function (s) { return s.id === activeServiceId[section]; });
            if (!svc) { svc = services[0]; activeServiceId[section] = svc.id; }
            return svc;
        }

        function setActiveOrderSection(section) {
            activeOrderSection = section;
            document.getElementById('chartSelectTop').classList.toggle('active', section === 'top');
            document.getElementById('chartSelectBottom').classList.toggle('active', section === 'bottom');
            renderServiceTabs();
            refreshAllOrderOverlays();
        }

        function renderServiceTabs() {
            const holder = document.getElementById('serviceTabRow');
            if (!holder) return;
            const services = getMealServices(activeOrderSection);
            if (services.length && !activeServiceId[activeOrderSection]) {
                activeServiceId[activeOrderSection] = services[0].id;
            }
            holder.innerHTML = services.map(function (svc) {
                const isActive = svc.id === activeServiceId[activeOrderSection];
                return '<span class="service-tab' + (isActive ? ' active' : '') + '" onclick="selectServiceTab(\'' + svc.id + '\')">' + svc.label + '</span>';
            }).join('');
        }

        function selectServiceTab(serviceId) {
            activeServiceId[activeOrderSection] = serviceId;
            renderServiceTabs();
            refreshAllOrderOverlays();
        }

        function addMealService() {
            const services = getMealServices(activeOrderSection);
            const svc = { id: 'service_' + Date.now() + '_' + Math.floor(Math.random() * 1000), label: 'Meal Service ' + (services.length + 1), menu: [] };
            services.push(svc);
            activeServiceId[activeOrderSection] = svc.id;
            renderServiceTabs();
            persistChartState();
            openMealMenuSetup();
        }

        function penGap(value) {
            return value + '<span class="pen-gap">___</span>';
        }

        function renderMealCountSummary(section) {
            const holder = document.getElementById(section + 'MealOrderSummary');
            if (!holder) return;
            const services = getMealServices(section);
            if (!services.length) { holder.innerHTML = ''; return; }
            const data = dataForSection(section);
            const passengers = (data && data.passengers) ? data.passengers : [];
            const serviceParts = services.map(function (svc) {
                const parts = svc.menu.map(function (choice) {
                    const ordered = passengers.filter(function (p) { return p.orders && p.orders[svc.id] && p.orders[svc.id].choiceId === choice.id; }).length;
                    return choice.name + ': ' + penGap(ordered);
                });
                return '<strong>' + svc.label + ':</strong> ' + (parts.join(' &nbsp;|&nbsp; ') || '<span style="color:#94a3b8;">no choices set</span>');
            });
            holder.innerHTML = serviceParts.join('<br>');
        }

        // ---- Meal Menu setup ----
        function openMealMenuSetup() {
            if (getMealServices(activeOrderSection).length === 0) {
                addMealService();
                return;
            }
            renderMealMenuSetup();
            document.getElementById('mealMenuOverlay').style.display = 'flex';
        }

        function renderMealMenuSetup() {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            const isCustom = !['Breakfast','Brunch','Lunch','Dinner','All Day Dining','Supper','Refreshments','DAT'].includes(svc.label);
            
            let html = '<div class="edit-modal-title">Meal Menu \u2014 ' + (activeOrderSection === 'top' ? 'Top' : 'Bottom') + ' Chart</div>';
            
            html += '<label>Service name</label>';
            html += `<select id="serviceNameSelect" onchange="handleServiceNameChange(this.value)" style="width:100%; box-sizing:border-box; padding:8px; border:1px solid #dee2e6; border-radius:6px; font-size:13px; margin-bottom:6px;">
                <option value="Breakfast" ${svc.label === 'Breakfast' ? 'selected' : ''}>Breakfast</option>
                <option value="Brunch" ${svc.label === 'Brunch' ? 'selected' : ''}>Brunch</option>
                <option value="Lunch" ${svc.label === 'Lunch' ? 'selected' : ''}>Lunch</option>
                <option value="Dinner" ${svc.label === 'Dinner' ? 'selected' : ''}>Dinner</option>
                <option value="All Day Dining" ${svc.label === 'All Day Dining' ? 'selected' : ''}>All Day Dining</option>
                <option value="Supper" ${svc.label === 'Supper' ? 'selected' : ''}>Supper</option>
                <option value="Refreshments" ${svc.label === 'Refreshments' ? 'selected' : ''}>Refreshments</option>
                <option value="DAT" ${svc.label === 'DAT' ? 'selected' : ''}>DAT</option>
                <option value="Custom" ${isCustom ? 'selected' : ''}>Custom</option>
            </select>`;
            html += `<input type="text" id="customServiceName" style="width:100%; box-sizing:border-box; padding:8px; border:1px solid #dee2e6; border-radius:6px; font-size:13px; margin-bottom:10px; display:${isCustom ? 'block' : 'none'};" value="${isCustom ? svc.label : ''}" oninput="updateServiceLabel(this.value)" placeholder="Type custom service name...">`;

            html += '<div id="mealMenuRows" style="margin-top:10px;">';
            if (svc.menu.length === 0) {
                html += '<div style="font-size:11px;color:#94a3b8;margin-bottom:8px;">No meal choices yet. Add the options loaded for this flight.</div>';
            }
            svc.menu.forEach(function (choice) {
                const randId = 'name_' + choice.id + '_' + Date.now();
                const qtyId = 'qty_' + choice.id + '_' + Date.now();
                html += '<div class="meal-menu-row">' +
                    `<input type="text" id="${randId}" class="meal-menu-name" value="${choice.name.replace(/"/g, '&quot;')}" onfocus="openNamePreset(this.id)" onchange="updateMealMenuField('${choice.id}','name',this.value)">` +
                    `<input type="number" id="${qtyId}" class="meal-menu-qty" value="${choice.qty}" onfocus="openKeypad(this.id)" onchange="updateMealMenuField('${choice.id}','qty',this.value)">` +
                    '<button class="meal-menu-remove-btn" onclick="removeMealChoice(\'' + choice.id + '\')">\u2715</button>' +
                    '</div>';
            });
            html += '</div>';
            html += '<button class="add-meal-choice-btn" onclick="addMealChoice()">+ Add meal choice</button>';
            html += '<button class="btn-close-panel" onclick="closeMealMenuSetup()">Done</button>';
            document.getElementById('mealMenuBody').innerHTML = html;
        }

        function handleServiceNameChange(value) {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            const customInput = document.getElementById('customServiceName');
            if (value === 'Custom') {
                customInput.style.display = 'block';
                customInput.value = '';
                svc.label = '';
            } else {
                customInput.style.display = 'none';
                svc.label = value;
                renderServiceTabs();
                renderMealCountSummary(activeOrderSection);
                persistChartState();
            }
        }

        function openNamePreset(inputId) {
            activePresetInputId = inputId;
            const popup = document.getElementById('presetPopup');
            const grid = document.getElementById('presetGrid');
            grid.innerHTML = PRESET_NAMES.map(name => 
                `<button class="preset-btn" onclick="selectPresetName('${name}')">${name}</button>`
            ).join('');
            document.getElementById('presetCustomInput').value = '';
            popup.style.display = 'flex';
        }
        function selectPresetName(name) {
            if (activePresetInputId) {
                document.getElementById(activePresetInputId).value = name;
                const evt = new Event('change', { bubbles: true });
                document.getElementById(activePresetInputId).dispatchEvent(evt);
                closeNamePreset();
            }
        }
        function customPresetName(val) {
            if (activePresetInputId && val.trim()) {
                document.getElementById(activePresetInputId).value = val.trim();
                const evt = new Event('change', { bubbles: true });
                document.getElementById(activePresetInputId).dispatchEvent(evt);
            }
        }
        function closeNamePreset() {
            document.getElementById('presetPopup').style.display = 'none';
            activePresetInputId = null;
        }

        function openKeypad(inputId) {
            activeKeypadInputId = inputId;
            document.getElementById('keypadDisplay').textContent = document.getElementById(inputId).value || '0';
            document.getElementById('keypadPopup').style.display = 'flex';
        }
        function keypadPress(value) {
            const display = document.getElementById('keypadDisplay');
            let current = display.textContent;
            if (value === 'backspace') {
                current = current.slice(0, -1) || '0';
            } else if (value === 'done') {
                if (activeKeypadInputId) {
                    const input = document.getElementById(activeKeypadInputId);
                    input.value = parseInt(current, 10) || 0;
                    const evt = new Event('change', { bubbles: true });
                    input.dispatchEvent(evt);
                    closeKeypad();
                    return;
                }
                return;
            } else {
                if (current === '0') current = value;
                else current += value;
            }
            display.textContent = current;
        }
        function closeKeypad() {
            document.getElementById('keypadPopup').style.display = 'none';
            activeKeypadInputId = null;
        }

        function updateServiceLabel(value) {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            svc.label = value || svc.label;
            renderServiceTabs();
            renderMealCountSummary(activeOrderSection);
            persistChartState();
        }

        function addMealChoice() {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            svc.menu.push({ id: 'meal_' + Date.now() + '_' + Math.floor(Math.random() * 1000), name: 'New Meal', qty: 0 });
            renderMealMenuSetup();
            renderMealCountSummary(activeOrderSection);
            persistChartState();
        }

        function removeMealChoice(choiceId) {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            const data = dataForSection(activeOrderSection);
            const idx = svc.menu.findIndex(function (c) { return c.id === choiceId; });
            if (idx === -1) return;
            if (data && data.passengers) {
                data.passengers.forEach(function (p) {
                    if (p.orders && p.orders[svc.id] && p.orders[svc.id].choiceId === choiceId) {
                        delete p.orders[svc.id];
                        refreshSeatOrderOverlayBySeat(activeOrderSection, p.seat);
                    }
                });
            }
            svc.menu.splice(idx, 1);
            renderMealMenuSetup();
            renderMealCountSummary(activeOrderSection);
            syncBackToMainPage();
            persistChartState();
        }

        function updateMealMenuField(choiceId, field, value) {
            const svc = getActiveService(activeOrderSection);
            if (!svc) return;
            const choice = svc.menu.find(function (c) { return c.id === choiceId; });
            if (!choice) return;
            if (field === 'qty') {
                choice.qty = Math.max(0, parseInt(value, 10) || 0);
            } else {
                choice.name = value;
                const data = dataForSection(activeOrderSection);
                if (data && data.passengers) {
                    data.passengers.forEach(function (p) {
                        if (p.orders && p.orders[svc.id] && p.orders[svc.id].choiceId === choiceId) refreshSeatOrderOverlayBySeat(activeOrderSection, p.seat);
                    });
                }
            }
            renderMealCountSummary(activeOrderSection);
            persistChartState();
        }

        function closeMealMenuSetup() { document.getElementById('mealMenuOverlay').style.display = 'none'; }

        // ---- Order-taking ----
        let orderLongPressTimer = null;
        let orderLongPressFired = false;

        function orderCellPressStart(seatBox) {
            orderLongPressFired = false;
            if (orderLongPressTimer) clearTimeout(orderLongPressTimer);
            orderLongPressTimer = setTimeout(function () {
                orderLongPressFired = true;
                openOrderModal(seatBox, true);
            }, 550);
        }
        function orderCellPressEnd() {
            if (orderLongPressTimer) { clearTimeout(orderLongPressTimer); orderLongPressTimer = null; }
        }

        function handleOrderTap(seatBox) {
            if (orderLongPressFired) { orderLongPressFired = false; return; }
            const section = sectionForBox(seatBox);
            if (section !== activeOrderSection) {
                showToast('Switch to the ' + (section === 'top' ? 'Top' : 'Bottom') + ' chart to take orders there');
                return;
            }
            const seat = seatBox.getAttribute('data-seat');
            const data = dataForSection(section);
            if (!data) { showToast('No manifest loaded for this chart yet'); return; }
            if (seatBox.classList.contains('empty-seat')) { showToast('No passenger in this seat'); return; }
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) { showToast('No passenger in this seat'); return; }
            if (p.meal && p.meal.trim()) { showToast('Seat ' + seat + ' already has a declared special meal: ' + p.meal); return; }
            const svc = getActiveService(section);
            if (!svc) { showToast('No meal service set up yet \u2014 tap 🍽️ Meal Menu first'); return; }

            p.orders = p.orders || {};
            const existing = p.orders[svc.id];
            if (!existing) {
                openOrderModal(seatBox);
            } else {
                existing.served = !existing.served;
                refreshSeatOrderOverlay(seatBox);
                syncBackToMainPage();
                persistChartState();
            }
        }

        function openOrderModal(seatBox, forceReopen) {
            const seat = seatBox.getAttribute('data-seat');
            const section = sectionForBox(seatBox);
            const data = dataForSection(section);
            if (!data) { showToast('No manifest loaded for this chart yet'); return; }
            if (seatBox.classList.contains('empty-seat')) { showToast('No passenger in this seat'); return; }
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p) { showToast('No passenger in this seat'); return; }
            if (p.meal && p.meal.trim() && !forceReopen) { showToast('Seat ' + seat + ' already has a declared special meal: ' + p.meal); return; }
            const svc = getActiveService(section);
            if (!svc) { showToast('No meal service set up yet \u2014 tap 🍽️ Meal Menu first'); return; }
            if (svc.menu.length === 0) { showToast('No meal choices set up yet \u2014 tap 🍽️ Meal Menu first'); return; }

            renderOrderModal(section, seat);
            document.getElementById('orderModalOverlay').style.display = 'flex';
        }

        function renderOrderModal(section, seat) {
            const data = dataForSection(section);
            const svc = getActiveService(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            const currentOrder = p.orders ? p.orders[svc.id] : null;
            const currentChoiceId = currentOrder ? currentOrder.choiceId : null;

            let html = '<div class="edit-modal-title">' + svc.label + ' \u2014 Seat ' + seat + '</div>';
            html += '<div id="orderMenuRows">';
            svc.menu.forEach(function (choice) {
                const isSelected = choice.id === currentChoiceId;
                const isDisabled = choice.qty <= 0 && !isSelected;
                html += '<div class="meal-menu-row' + (isDisabled ? ' disabled' : '') + '">' +
                    '<span class="meal-menu-name" style="border:none;padding:6px 0;">' + choice.name + ' (' + choice.qty + ' left)</span>' +
                    '<button class="meal-menu-select-btn' + (isSelected ? ' active' : '') + '" ' + (isDisabled ? 'disabled' : '') + ' onclick="selectMealChoice(\'' + section + '\',\'' + seat + '\',\'' + choice.id + '\')">' + (isSelected ? '\u2713 Selected' : 'Select') + '</button>' +
                    '</div>';
            });
            html += '</div>';
            if (currentOrder) {
                html += '<button class="add-meal-choice-btn" onclick="clearMealOrder(\'' + section + '\',\'' + seat + '\')">Clear order</button>';
            }
            html += '<button class="btn-close-panel" onclick="closeOrderModal()">Done</button>';

            document.getElementById('orderModalBody').innerHTML = html;
        }

        function selectMealChoice(section, seat, choiceId) {
            const data = dataForSection(section);
            if (!data || !data.passengers) return;
            const svc = getActiveService(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p || !svc) return;
            const newChoice = svc.menu.find(function (c) { return c.id === choiceId; });
            if (!newChoice) return;

            p.orders = p.orders || {};
            const existing = p.orders[svc.id];

            if (existing && existing.choiceId === choiceId) {
                newChoice.qty += 1;
                delete p.orders[svc.id];
            } else {
                if (newChoice.qty <= 0) { showToast('No more ' + newChoice.name + ' left'); return; }
                if (existing) {
                    const oldChoice = svc.menu.find(function (c) { return c.id === existing.choiceId; });
                    if (oldChoice) oldChoice.qty += 1;
                }
                newChoice.qty -= 1;
                p.orders[svc.id] = { choiceId: choiceId, served: false, remark: '' };
            }

            refreshSeatOrderOverlayBySeat(section, seat);
            syncBackToMainPage();
            persistChartState();
            renderMealCountSummary(section);
            closeOrderModal();
        }

        function clearMealOrder(section, seat) {
            const data = dataForSection(section);
            const svc = getActiveService(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p || !svc || !p.orders || !p.orders[svc.id]) { closeOrderModal(); return; }
            const choice = svc.menu.find(function (c) { return c.id === p.orders[svc.id].choiceId; });
            if (choice) choice.qty += 1;
            delete p.orders[svc.id];
            refreshSeatOrderOverlayBySeat(section, seat);
            syncBackToMainPage();
            persistChartState();
            renderMealCountSummary(section);
            closeOrderModal();
        }

        function refreshSeatOrderOverlayBySeat(section, seat) {
            const normSeat = normalizeSeatNumber(seat);
            const seatBox = document.querySelector('#' + section + 'SeatContainer [data-seat="' + normSeat + '"]');
            if (seatBox) refreshSeatOrderOverlay(seatBox);
        }

        // ================================================================
        // UPDATED: Overlay rendering with Full Cell cover & Event stopPropagation
        // ================================================================
        function refreshSeatOrderOverlay(seatBox) {
            const overlay = seatBox.querySelector('.order-fill-overlay');
            if (!overlay) return;
            const section = sectionForBox(seatBox);
            const seat = seatBox.getAttribute('data-seat');
            const data = dataForSection(section);
            const svc = getActiveService(section);
            const p = data && data.passengers ? data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; }) : null;
            const order = (p && svc && p.orders) ? p.orders[svc.id] : null;
            const seatNumberContainer = seatBox.querySelector('.seat-number-container');

            // Manage the hidden state of the original title bar and the overlay class
            if (order) {
                seatBox.classList.add('has-order');
                seatNumberContainer.style.visibility = 'hidden';
                overlay.style.display = 'flex';
            } else {
                seatBox.classList.remove('has-order');
                seatNumberContainer.style.visibility = 'visible';
                overlay.style.display = 'none';
                overlay.innerHTML = '';
                return;
            }

            let html = '';
            if (order.served) {
                overlay.style.backgroundColor = '#dcfce7';
                overlay.style.color = '#166534';
                // Embed the seat number, make checkmark huge
                html = `
                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; position:relative;">
                        <div style="position:absolute; top:2px; left:4px; font-size:0.6em; font-weight:bold; color:#333;">${seat}</div>
                        <span class="order-fill-icon">\u2705</span>
                    </div>
                `;
            } else {
                const choice = svc.menu.find(function (c) { return c.id === order.choiceId; });
                const letter = choice && choice.name ? choice.name.trim().charAt(0).toUpperCase() : '?';
                const c = getOrderColor(order.choiceId);
                overlay.style.backgroundColor = c.bg;
                overlay.style.color = c.text;
                const remark = order.remark || '';
                // Embed the seat number + letter + remarks input. Stop mouse/touch events bubbling up so typing doesn't toggle served.
                html = `
                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; position:relative;">
                        <div style="position:absolute; top:2px; left:4px; font-size:0.6em; font-weight:bold; color:#333;">${seat}</div>
                        <span class="order-fill-letter">${letter}</span>
                        <input type="text" class="order-remark-input" value="${remark.replace(/"/g, '&quot;')}" placeholder="Remarks" onmousedown="event.stopPropagation()" ontouchstart="event.stopPropagation()" oninput="updateOrderRemark('${section}','${seat}',this.value)">
                    </div>
                `;
            }
            overlay.innerHTML = html;
        }

        function updateOrderRemark(section, seat, value) {
            const data = dataForSection(section);
            const svc = getActiveService(section);
            const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
            if (!p || !svc) return;
            if (!p.orders) p.orders = {};
            if (!p.orders[svc.id]) return;
            p.orders[svc.id].remark = value;
            syncBackToMainPage();
            persistChartState();
        }

        function refreshAllOrderOverlays() {
            document.querySelectorAll('.seat-box').forEach(function (box) { refreshSeatOrderOverlay(box); });
        }

        function refreshSeatDisplay(section, seat) {
            refreshSeatOrderOverlayBySeat(section, seat);
        }

        function closeOrderModal() { document.getElementById('orderModalOverlay').style.display = 'none'; }

        // ============== SUMMARY CHIPS + CATEGORY LIST ==============
        function renderSummaryChips(section) {
            const holder = document.getElementById(section + 'SummaryChips');
            if (!holder) return;
            const data = dataForSection(section);
            const passengers = (data && data.passengers) ? data.passengers : [];

            const specialCounts = {};
            passengers.forEach(function (p) {
                const label = getSpecialLabel(p);
                if (label) specialCounts[label] = (specialCounts[label] || 0) + 1;
            });
            const infCount = passengers.filter(function (p) { return p.isInfant; }).length;
            const extCount = passengers.filter(function (p) { return p.extSeatbelt; }).length;
            const remarksCount = passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); }).length;

            let chips = [];
            Object.keys(specialCounts).sort().forEach(function (code) {
                chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'special\',\'' + code.replace(/'/g, "\\'") + '\')">' + code + ' (' + specialCounts[code] + ')</span>');
            });
            if (infCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'inf\')">INF (' + infCount + ')</span>');
            if (extCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'ext\')">EXT (' + extCount + ')</span>');
            if (remarksCount > 0) chips.push('<span class="summary-chip" onclick="openCategoryList(\'' + section + '\',\'remarks\')">REMARKS (' + remarksCount + ')</span>');

            holder.innerHTML = chips.join('');
        }

        function openCategoryList(section, category, code) {
            const data = dataForSection(section);
            const passengers = (data && data.passengers) ? data.passengers : [];
            let items = [];
            let title = '';

            if (category === 'special') {
                title = code + ' (' + passengers.filter(function (p) { return getSpecialLabel(p) === code; }).length + ')';
                items = passengers.filter(function (p) { return getSpecialLabel(p) === code; })
                    .map(function (p) { return { seat: p.seat || '—', name: p.name || '', tag: code }; });
            } else if (category === 'inf') {
                title = 'Infants (' + passengers.filter(function (p) { return p.isInfant; }).length + ')';
                items = passengers.filter(function (p) { return p.isInfant; })
                    .map(function (p) { return { seat: p.seat || '—', name: p.name || '', tag: 'INF' }; });
            } else if (category === 'ext') {
                title = 'Extension Seatbelt (' + passengers.filter(function (p) { return p.extSeatbelt; }).length + ')';
                items = passengers.filter(function (p) { return p.extSeatbelt; })
                    .map(function (p) { return { seat: p.seat || '—', name: p.name || '', tag: 'EXT' }; });
            } else if (category === 'remarks') {
                title = 'Remarks (' + passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); }).length + ')';
                items = passengers.filter(function (p) { return p.remarksText && p.remarksText.trim(); })
                    .map(function (p) { return { seat: p.seat || '—', name: p.name || '', tag: p.remarksText }; });
            }

            items.sort(function (a, b) {
                if (a.seat === '—') return 1;
                if (b.seat === '—') return -1;
                return normalizeSeatNumber(a.seat).localeCompare(normalizeSeatNumber(b.seat));
            });

            const listHTML = items.length === 0
                ? '<div style="padding:20px;text-align:center;color:#94a3b8;font-size:12px;">No passengers found.</div>'
                : items.map(function (it) {
                    return '<div class="category-list-row" onclick="closeCategoryList(); jumpToSeatEdit(\'' + section + '\',\'' + normalizeSeatNumber(it.seat) + '\');">' +
                        '<span class="category-list-seat">' + it.seat + '</span>' +
                        '<span class="category-list-name">' + (it.name || '—').replace(/\//g, ' / ') + '</span>' +
                        '<span class="category-list-tag">' + it.tag + '</span>' +
                        '</div>';
                }).join('');

            document.getElementById('categoryListBody').innerHTML =
                '<div class="color-panel-title">' + title + '</div>' +
                '<div class="category-list">' + listHTML + '</div>' +
                '<button class="btn-close-panel" onclick="closeCategoryList()">Close</button>';

            document.getElementById('categoryListOverlay').style.display = 'flex';
        }

        function jumpToSeatEdit(section, seat) {
            const containerId = section + 'SeatContainer';
            const seatBox = document.querySelector('#' + containerId + ' [data-seat="' + seat + '"]');
            if (seatBox) {
                setMode('edit');
                openInfoEditModal(seatBox);
