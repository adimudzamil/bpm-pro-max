        // ============== SWAP SEATS ==============
        function handleSwapTap(seatBox) {
            if (!swapFirstSeat) {
                swapFirstSeat = seatBox;
                seatBox.classList.add('swap-selected');
                return;
            }
            if (swapFirstSeat === seatBox) { clearSwapSelection(); return; }
            swapPassengers(swapFirstSeat, seatBox);
            clearSwapSelection();
        }

        function swapPassengers(boxA, boxB) {
            const seatA = boxA.getAttribute('data-seat');
            const seatB = boxB.getAttribute('data-seat');
            const section = sectionForBox(boxA);
            if (sectionForBox(boxB) !== section) { showToast('Can only swap within the same service'); return; }
            const data = dataForSection(section);
            if (!data) return;
            if (!data.passengers) data.passengers = [];

            let pA = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seatA; });
            let pB = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seatB; });

            if (pA && pB) {
                const tempA = Object.assign({}, pA);
                Object.assign(pA, pB); pA.seat = seatA;
                Object.assign(pB, tempA); pB.seat = seatB;
            } else if (pA && !pB) {
                pA.seat = seatB;
            } else if (!pA && pB) {
                pB.seat = seatA;
            } else {
                showToast('Both seats are empty');
                return;
            }

            [boxA, boxB].forEach(function (box) {
                const seat = box.getAttribute('data-seat');
                const p = data.passengers.find(function (x) { return normalizeSeatNumber(x.seat) === seat; });
                clearTierClasses(box);
                if (p) { box.classList.remove('empty-seat'); populateSeatData(p, box); } else { markSeatAsEmpty(box); }
            });

            syncBackToMainPage();
            persistChartState();
            renderSummaryChips(section);
            showToast('Swapped ' + seatA + ' \u2194 ' + seatB);
        }

        function clearTierClasses(seatBox) {
            Object.keys(DEFAULT_TIER_COLORS).forEach(function (t) { seatBox.classList.remove('tier-' + t); });
        }

        // ============== SYNC BACK TO MAIN PAGE ==============
        function syncBackToMainPage() {
            try {
                const tabId = (topChartData && topChartData.tabId) || (bottomChartData && bottomChartData.tabId);
                if (!tabId) return;
                const raw = localStorage.getItem(TABS_STORAGE_KEY);
                if (!raw) return;
                const tabs = JSON.parse(raw);
                const tab = tabs.find(function (t) { return t.id === tabId; });
                if (!tab || !tab.passengers) return;
                [topChartData, bottomChartData].forEach(function (data) {
                    if (!data || !data.passengers) return;
                    data.passengers.forEach(function (p) {
                        const idx = tab.passengers.findIndex(function (tp) { return tp.seat === p.seat; });
                        if (idx !== -1) tab.passengers[idx] = Object.assign({}, tab.passengers[idx], p);
                    });
                });
                localStorage.setItem(TABS_STORAGE_KEY, JSON.stringify(tabs));
            } catch (e) { console.error('Sync back failed', e); }
        }

        // ============== EXISTING APP LOGIC ==============
        let isAftView = false;
        let currentFontSize = 12;
        let currentRowCount = 4;
        let topChartData = null;
        let bottomChartData = null;
        let currentTabId = null;
        
