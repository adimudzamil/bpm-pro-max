        function renderTierColorChips() {
            const holder = document.getElementById('tierColorChips');
            holder.innerHTML = Object.keys(DEFAULT_TIER_COLORS).map(function (t) {
                const c = theme.tiers[t] || DEFAULT_TIER_COLORS[t];
                return '<span class="tier-chip" style="background:' + c.bg + ';color:' + c.text + ';" onclick="openTierColorPanel(\'' + t + '\')">' + t + '</span>';
            }).join('');
        }

        function toggleSwapMode() {
            swapModeActive = !swapModeActive;
            clearSwapSelection();
            document.getElementById('swapSeatsBtn').classList.toggle('active', swapModeActive);
            document.getElementById('swapHint').style.display = swapModeActive ? 'inline-block' : 'none';
        }

        function toggleMoreControls() {
            document.getElementById('controlBar').classList.toggle('collapsed');
        }

        function clearSwapSelection() {
            if (swapFirstSeat) swapFirstSeat.classList.remove('swap-selected');
            swapFirstSeat = null;
        }

        document.addEventListener('click', function (e) {
            if (currentMode === 'view') return;

            if (currentMode === 'edit') {
                const seatBox = e.target.closest('.seat-box');
                if (!seatBox) return;
                if (swapModeActive) { handleSwapTap(seatBox); return; }
                openInfoEditModal(seatBox);
                return;
            }

            if (currentMode === 'order') {
                const seatBox = e.target.closest('.seat-box');
                if (!seatBox) return;
                handleOrderTap(seatBox);
                return;
            }

            if (currentMode === 'color') {
                const tierBadge = e.target.closest('.tier');
                if (tierBadge) {
                    const tierClass = Array.from(tierBadge.classList).find(function (c) { return c.indexOf('tier-') === 0; });
                    if (tierClass) { openTierColorPanel(tierClass.replace('tier-', '')); }
                    return;
                }
                const mealCodeSpan = e.target.closest('.meal-code-part');
                if (mealCodeSpan) {
                    openMealColorPanel(mealCodeSpan.getAttribute('data-meal-code'));
                    return;
                }
                const orderCodeSpan = e.target.closest('.order-code-part');
                if (orderCodeSpan) {
                    const choiceId = orderCodeSpan.getAttribute('data-order-choice');
                    const orderSeatBox = orderCodeSpan.closest('.seat-box');
                    openOrderColorPanel(choiceId, orderSeatBox ? sectionForBox(orderSeatBox) : 'top');
                    return;
                }
                const specialCodeSpan = e.target.closest('.special-code-part');
                if (specialCodeSpan) {
                    openSpecialColorPanel(specialCodeSpan.getAttribute('data-special-code'));
                    return;
                }
                const mealLineEmpty = e.target.closest('.field-line.meal-line');
                if (mealLineEmpty && !mealLineEmpty.querySelector('.meal-code-part, .special-code-part, .order-code-part')) {
                    openColorPanel([{ key: 'mealBg', label: 'Meal line background (default)' }, { key: 'mealText', label: 'Meal line text (default)' }], 'Meal Line (no code set)');
                    return;
                }
                const titleLine = e.target.closest('.name-line.title-line');
                if (titleLine) { openColorPanel([{ key: 'titleColor', label: 'Title text colour' }], 'Title Line'); return; }
                const nameLine = e.target.closest('.name-line.surname-line, .name-line.firstname-line');
                if (nameLine) { openColorPanel([{ key: 'nameColor', label: 'Name text colour' }], 'Passenger Name'); return; }
                const header = e.target.closest('.seat-number-container');
                if (header) {
                    openColorPanel([{ key: 'headerBg', label: 'Header background' }, { key: 'headerText', label: 'Header text' }], 'Seat Number Header');
                    return;
                }
                const box = e.target.closest('.seat-box');
                if (box) {
                    openColorPanel([{ key: 'seatBg', label: 'Seat background' }, { key: 'borderColor', label: 'Border colour' }, { key: 'emptyPlaceholder', label: 'Empty seat placeholder' }], 'Seat Box');
                }
            }
        });

        document.addEventListener('mousedown', function (e) {
            if (currentMode !== 'order') return;
            const seatBox = e.target.closest('.seat-box');
            if (!seatBox) return;
            orderCellPressStart(seatBox);
        });
        document.addEventListener('touchstart', function (e) {
            if (currentMode !== 'order') return;
            const seatBox = e.target.closest('.seat-box');
            if (!seatBox) return;
            orderCellPressStart(seatBox);
        }, { passive: true });
        document.addEventListener('mouseup', orderCellPressEnd);
        document.addEventListener('touchend', orderCellPressEnd);
        document.addEventListener('touchmove', orderCellPressEnd);

        // ============== COLOUR PANELS ==============
        function openColorPanel(fields, title) {
            let html = '<div class="color-panel-title">' + title + '</div>';
            fields.forEach(function (f) {
                const val = theme.structural[f.key] || '#000000';
                html += '<div class="color-field"><label>' + f.label + '</label><input type="color" value="' + val + '" onchange="updateStructuralColor(\'' + f.key + '\', this.value)"></div>';
